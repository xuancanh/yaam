{
  "manifest": 3,
  "name": "Dev Kitchen Sink",
  "version": "1.0.0",
  "icon": "🧪",
  "description": "Developer reference — a tab that exercises every addon capability (state, sessions, tasks incl. review verbs, templates, schedules, storage, allowlisted HTTP, keychain secrets, the addon's own agent, UI calls), plus all four hooks, a Master tool, and a masterPromptAppend. Built on toolkit/sdk.js + ui.css.",
  "author": "yaam",
  "permissions": [
    "state:read",
    "sessions:send",
    "sessions:launch",
    "tasks",
    "schedules",
    "agent",
    "master:prompt",
    "ui",
    "storage",
    "http",
    "secrets"
  ],
  "hosts": [
    "api.github.com"
  ],
  "secrets": [
    {
      "name": "DEMO_TOKEN",
      "label": "any string — only used to demo {{secret:…}} header templating"
    }
  ],
  "tools": [
    {
      "name": "sink_echo",
      "description": "Kitchen-sink demo tool — echoes its input back with a state summary, proving Master can call addon tools.",
      "input_schema": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "description": "anything; it comes straight back"
          }
        },
        "required": [
          "text"
        ]
      },
      "handler": "// A Master tool handler: (input, api) => string. Master sees the returned\n// string as the tool result. Prove we can both read input and touch the api.\nconst state = api.getState()\nconst summary = state\n  ? `${state.sessions.length} session(s), ${state.tasks.length} task(s), $${state.totals.cost} spent`\n  : 'state:read not granted'\nreturn `echo: ${String(input.text)} — app right now: ${summary}`\n"
    }
  ],
  "hooks": {
    "onSessionExit": "// Shared hook body (wired to all four hooks in addon.yaml). Hooks receive\n// (input = the event, api = the permission-scoped AddonApi) and run in the\n// sandbox — every api method except getState is async, so ALWAYS await.\n// This one just records the event so the view's \"Hook log\" section can show\n// hooks firing in real time.\nconst log = (await api.storage.get('hookLog')) || []\nlog.unshift({ at: Date.now(), event: input })\nawait api.storage.set('hookLog', log.slice(0, 100))\n",
    "onNeedsInput": "// Shared hook body (wired to all four hooks in addon.yaml). Hooks receive\n// (input = the event, api = the permission-scoped AddonApi) and run in the\n// sandbox — every api method except getState is async, so ALWAYS await.\n// This one just records the event so the view's \"Hook log\" section can show\n// hooks firing in real time.\nconst log = (await api.storage.get('hookLog')) || []\nlog.unshift({ at: Date.now(), event: input })\nawait api.storage.set('hookLog', log.slice(0, 100))\n",
    "onTaskMoved": "// Shared hook body (wired to all four hooks in addon.yaml). Hooks receive\n// (input = the event, api = the permission-scoped AddonApi) and run in the\n// sandbox — every api method except getState is async, so ALWAYS await.\n// This one just records the event so the view's \"Hook log\" section can show\n// hooks firing in real time.\nconst log = (await api.storage.get('hookLog')) || []\nlog.unshift({ at: Date.now(), event: input })\nawait api.storage.set('hookLog', log.slice(0, 100))\n",
    "onCronFired": "// Shared hook body (wired to all four hooks in addon.yaml). Hooks receive\n// (input = the event, api = the permission-scoped AddonApi) and run in the\n// sandbox — every api method except getState is async, so ALWAYS await.\n// This one just records the event so the view's \"Hook log\" section can show\n// hooks firing in real time.\nconst log = (await api.storage.get('hookLog')) || []\nlog.unshift({ at: Date.now(), event: input })\nawait api.storage.set('hookLog', log.slice(0, 100))\n",
    "masterPromptAppend": "When the user asks what addons can do, mention that the Dev Kitchen Sink tab demonstrates the whole addon API."
  },
  "agent": {
    "system": "You are the Dev Kitchen Sink agent — a live demo of an addon's own mini-orchestrator. Your tools ARE this addon's permission-scoped API (get_state, read_output, add_task, get_task, approve_task, reject_task, restart_task, task_chat, add_schedule, run_template, http_request, storage, notify_user, send_to_session, launch_session, stop_session).\n\nWhen woken from the tab, do what the note asks, preferring to demonstrate: read state before acting, use one or two tools, and reply with a short concrete summary of what you did and which tools you used. If a tool is denied, say which permission is missing instead of retrying.\n\nYou exist so addon authors can see the agent loop working — be brief, factual, and slightly enthusiastic about being a demo.\n"
  },
  "html": "<!DOCTYPE html><html><head><style>\n/* YAAM addon UI kit — design tokens + components matching the host app.\n   Inline it into your view's <style> block with an @include marker (see\n   toolkit/README.md); the sandbox CSP forbids external stylesheets. */\n/* ---------- tokens ---------- */\n:root{\n  --bg:#0A0B0F; --panel:#12151C; --panel2:#0D0F14;\n  --line:#1a1e26; --line2:#23272F;\n  --text:#E7E9F0; --mut:#8B93A1; --dim:#5a6170;\n  --acc:#F5C451; --green:#3DDC97; --red:#FF5C5C; --amber:#FFB020;\n  --font-sans:'IBM Plex Sans',system-ui,sans-serif;\n  --font-mono:'JetBrains Mono',monospace;\n}\n/* ---------- base ---------- */\n*{box-sizing:border-box}\nbody{margin:0;background:var(--bg);color:var(--text);font-family:var(--font-sans);font-size:13px;padding:24px}\n.mono{font-family:var(--font-mono)}\nh1{font-size:15px;margin:0;display:flex;gap:9px;align-items:center}\n.sub{font-size:11.5px;color:var(--dim);margin-top:4px}\nh2{font-size:10px;letter-spacing:.6px;color:var(--dim);margin:24px 0 8px;text-transform:uppercase;font-weight:600;display:flex;gap:8px;align-items:baseline}\na{color:var(--acc);text-decoration:none}\n/* ---------- layout ---------- */\n.card{background:var(--panel);border:1px solid var(--line);border-radius:11px;padding:13px 15px;margin-bottom:8px}\n.row{display:flex;gap:9px;align-items:center;flex-wrap:wrap}\n.grow{flex:1}\n.empty{color:var(--dim);font-size:12px;padding:8px 2px}\n/* ---------- controls ---------- */\nbutton{background:transparent;border:1px solid var(--line2);border-radius:8px;color:var(--text);font-size:11.5px;padding:6px 13px;cursor:pointer;font-family:var(--font-sans);transition:border-color .12s,color .12s,background .12s}\nbutton:hover{border-color:var(--acc);color:var(--acc)}\nbutton:disabled{opacity:.4;cursor:default;pointer-events:none}\nbutton.primary{border-color:rgba(61,220,151,.45);color:var(--green)}\nbutton.primary:hover{background:rgba(61,220,151,.08)}\nbutton.danger:hover{border-color:var(--red);color:var(--red)}\nbutton.ghost{border-color:transparent;color:var(--mut);padding:6px 8px}\nbutton.ghost:hover{color:var(--acc)}\ninput,textarea,select{background:var(--bg);border:1px solid var(--line2);border-radius:8px;color:var(--text);font-size:11.5px;padding:6px 9px;outline:none;font-family:var(--font-sans)}\ninput:focus,textarea:focus,select:focus{border-color:rgba(245,196,81,.45)}\nlabel.f{display:flex;flex-direction:column;gap:3px;font-size:9.5px;color:var(--dim);text-transform:uppercase;letter-spacing:.4px;font-weight:600}\n.chk{display:flex;gap:7px;align-items:center;font-size:11.5px;color:var(--mut);cursor:pointer}\n.chk input{width:auto;accent-color:var(--acc)}\n/* ---------- indicators ---------- */\n.dot{width:7px;height:7px;border-radius:50%;display:inline-block;background:var(--line2);flex:none}\n.dot.on,.dot.done,.dot.ok{background:var(--green)}\n.dot.running,.dot.amber{background:var(--amber);animation:yaam-pulse 1.1s ease-in-out infinite}\n.dot.failed,.dot.err{background:var(--red)}\n@keyframes yaam-pulse{50%{opacity:.35}}\n.chip{font-family:var(--font-mono);font-size:10px;color:var(--mut);border:1px solid var(--line2);border-radius:6px;padding:2px 9px}\n.chip b{color:var(--text)}\n.pill{font-family:var(--font-mono);font-size:10px;font-weight:700;border-radius:5px;padding:1px 8px;border:1px solid}\n.pill.ok,.pill.done{color:var(--green);border-color:rgba(61,220,151,.4)}\n.pill.warn,.pill.running{color:var(--amber);border-color:rgba(255,176,32,.4)}\n.pill.err,.pill.failed{color:var(--red);border-color:rgba(255,92,92,.4)}\n.pill.mut{color:var(--dim);border-color:var(--line2)}\n.meta{font-family:var(--font-mono);font-size:10px;color:var(--dim)}\n@keyframes yaam-spin{to{transform:rotate(360deg)}}\n.spin{display:inline-block;animation:yaam-spin .8s linear infinite}\n/* ---------- callouts & the SDK banner ---------- */\n.callout{background:var(--panel2);border:1px dashed var(--line2);border-radius:9px;padding:9px 12px;font-size:11.5px;color:var(--mut);line-height:1.55}\n#yaam-banner{display:none;background:rgba(255,92,92,.08);border:1px solid rgba(255,92,92,.3);color:var(--red);font-size:11.5px;padding:8px 12px;border-radius:9px;margin-bottom:12px}\n/* ---------- lists ---------- */\n.lrow{display:flex;gap:10px;align-items:center;font-size:11.5px;padding:7px 2px;border-bottom:1px solid var(--line)}\n.lrow:last-child{border-bottom:none}\nkbd{font-family:var(--font-mono);font-size:9px;border:1px solid var(--line2);border-radius:4px;padding:0 4px;color:var(--mut)}\n\nbody{max-width:940px}\npre{background:var(--panel2);border:1px solid var(--line);border-radius:9px;padding:10px 12px;font-family:var(--font-mono);font-size:10.5px;color:var(--mut);overflow:auto;max-height:220px;margin:8px 0 0;white-space:pre-wrap;word-break:break-word}\ndetails summary{cursor:pointer;font-size:11px;color:var(--mut);user-select:none}\n.grid2{display:grid;grid-template-columns:1fr 1fr;gap:8px}\n.sess .nm,.task .nm{font-size:12px;font-weight:600}\n.bubble{max-width:85%;border:1px solid var(--line2);border-radius:10px;padding:7px 11px;font-size:12px;line-height:1.5;margin-bottom:6px}\n.bubble.you{margin-left:auto;background:var(--panel2);border-radius:10px 10px 3px 10px}\n.bubble.bot{background:var(--panel);border-radius:10px 10px 10px 3px;color:var(--mut)}\n.sect-note{font-size:10.5px;color:var(--dim);margin:-4px 0 8px;line-height:1.5}\n</style></head><body>\n<h1>🧪 Dev Kitchen Sink</h1>\n<div class=\"sub\">every addon capability, live — read alongside <span class=\"mono\">docs/addons.md</span> and <span class=\"mono\">toolkit/README.md</span></div>\n\n<h2>1 · State snapshot <span class=\"mono\" style=\"letter-spacing:0;text-transform:none\">state:read</span></h2>\n<div class=\"sect-note\">pushed into the view every ~3s; also sync via <span class=\"mono\">yaam.onState(cb)</span></div>\n<div class=\"card\" id=\"snapshot\"><span class=\"empty\">waiting…</span></div>\n\n<h2>2 · Sessions <span class=\"mono\" style=\"letter-spacing:0;text-transform:none\">sessions:send · sessions:launch</span></h2>\n<div class=\"card\">\n  <div class=\"row\">\n    <label class=\"f\">command<input id=\"lCmd\" value=\"sleep 30 && echo done\" style=\"width:220px\"></label>\n    <label class=\"f\">cwd<input id=\"lCwd\" placeholder=\"(default)\" style=\"width:140px\"></label>\n    <label class=\"f\">name<input id=\"lName\" value=\"sink demo\" style=\"width:110px\"></label>\n    <button class=\"primary\" style=\"align-self:flex-end\" onclick=\"launch()\">Launch session</button>\n  </div>\n</div>\n<div id=\"sessions\"></div>\n\n<h2>3 · Tasks <span class=\"mono\" style=\"letter-spacing:0;text-transform:none\">tasks — full spec + review verbs</span></h2>\n<div class=\"card\">\n  <div class=\"row\">\n    <label class=\"f\">title<input id=\"tTitle\" value=\"kitchen-sink demo task\" style=\"width:200px\"></label>\n    <label class=\"f\">column<select id=\"tCol\"><option>backlog</option><option>progress</option><option>review</option></select></label>\n    <label class=\"f\">session<select id=\"tMode\"><option value=\"\">one-shot</option><option value=\"interactive\">interactive</option></select></label>\n    <label class=\"f\">start in<select id=\"tWhen\"><option value=\"\">now / manual</option><option value=\"2\">2 min (scheduleAt)</option><option value=\"10\">10 min</option></select></label>\n  </div>\n  <div class=\"row\" style=\"margin-top:8px\">\n    <label class=\"f grow\">description<input id=\"tDesc\" value=\"Say hello and exit — created by the Dev Kitchen Sink addon.\"></label>\n    <label class=\"chk\" style=\"align-self:flex-end\"><input type=\"checkbox\" id=\"tIso\"> worktree ⑂</label>\n    <label class=\"chk\" style=\"align-self:flex-end\"><input type=\"checkbox\" id=\"tStart\"> start now</label>\n    <button class=\"primary\" style=\"align-self:flex-end\" onclick=\"addTask()\">Create</button>\n  </div>\n</div>\n<div id=\"tasks\"></div>\n\n<h2>4 · Templates <span class=\"mono\" style=\"letter-spacing:0;text-transform:none\">templates.list / templates.run</span></h2>\n<div id=\"templates\" class=\"card\"></div>\n\n<h2>5 · Schedules <span class=\"mono\" style=\"letter-spacing:0;text-transform:none\">schedules + run history</span></h2>\n<div class=\"card row\">\n  <label class=\"f\">name<input id=\"cName\" value=\"sink-heartbeat\" style=\"width:130px\"></label>\n  <label class=\"f\">cron<input id=\"cCron\" class=\"mono\" value=\"*/5 * * * *\" style=\"width:110px\"></label>\n  <label class=\"f\">or one-time in<select id=\"cAt\"><option value=\"\">use cron</option><option value=\"2\">2 min</option><option value=\"5\">5 min</option></select></label>\n  <button class=\"primary\" style=\"align-self:flex-end\" onclick=\"addSchedule()\">Add schedule</button>\n  <span class=\"grow\"></span>\n  <span class=\"meta\">firing = an onCronFired hook + a row in §9</span>\n</div>\n<div id=\"crons\"></div>\n\n<h2>6 · Storage <span class=\"mono\" style=\"letter-spacing:0;text-transform:none\">get / set / list / remove · 256 KB per value</span></h2>\n<div class=\"card\">\n  <div class=\"row\">\n    <label class=\"f\">key<input id=\"sKey\" value=\"demo\" style=\"width:120px\"></label>\n    <label class=\"f grow\">value (JSON or plain text)<input id=\"sVal\" value='{\"hello\":\"world\"}'></label>\n    <button onclick=\"storSet()\" style=\"align-self:flex-end\">set</button>\n    <button onclick=\"storGet()\" style=\"align-self:flex-end\">get</button>\n    <button class=\"danger\" onclick=\"storDel()\" style=\"align-self:flex-end\">remove</button>\n  </div>\n  <pre id=\"sOut\">keys: …</pre>\n</div>\n\n<h2>7 · HTTP + secrets <span class=\"mono\" style=\"letter-spacing:0;text-transform:none\">http (host-allowlisted) · secrets (keychain, write-only)</span></h2>\n<div class=\"sect-note\">this addon declares <span class=\"mono\">hosts: [api.github.com]</span> — anything else is rejected before it leaves the app. Header/body values may embed <span class=\"mono\">{{secret:DEMO_TOKEN}}</span>; the value is injected host-side and never enters addon code.</div>\n<div class=\"card\">\n  <div class=\"row\">\n    <label class=\"f\">method<select id=\"hMethod\"><option>GET</option><option>POST</option></select></label>\n    <label class=\"f grow\">url (must match the hosts allowlist)<input id=\"hUrl\" class=\"mono\" value=\"https://api.github.com/zen\"></label>\n    <button class=\"primary\" id=\"hGo\" style=\"align-self:flex-end\" onclick=\"httpGo()\">Send</button>\n  </div>\n  <div class=\"row\" style=\"margin-top:8px\">\n    <label class=\"f grow\">headers (JSON — try {\"x-demo\": \"{{secret:DEMO_TOKEN}}\"})<input id=\"hHead\" class=\"mono\" value='{\"accept\": \"application/vnd.github+json\"}'></label>\n  </div>\n  <pre id=\"hOut\">response appears here — try a disallowed host to see the allowlist reject it</pre>\n  <div class=\"row\" style=\"margin-top:6px\"><span class=\"meta\" id=\"secretsLine\">secrets: …</span></div>\n</div>\n\n<h2>8 · The addon's agent <span class=\"mono\" style=\"letter-spacing:0;text-transform:none\">agent.wake → its tools are this addon's API</span></h2>\n<div class=\"sect-note\">the same harness the GitHub-issues triage and usage-limit monitors use — its instructions live in <span class=\"mono\">prompts/agent.md</span> and are editable via the addon's Customize chat. Add <span class=\"mono\">every:</span>/<span class=\"mono\">on:</span> in the manifest to wake it on crons/events.</div>\n<div class=\"card\">\n  <div id=\"chat\" style=\"display:flex;flex-direction:column\"></div>\n  <div class=\"row\">\n    <input id=\"aMsg\" class=\"grow\" placeholder='try: \"how many sessions are running? store the answer under key agent-note\"' onkeydown=\"if(event.key==='Enter')wake()\">\n    <button class=\"primary\" id=\"aGo\" onclick=\"wake()\">Wake agent</button>\n  </div>\n</div>\n\n<h2>9 · UI calls + hook log <span class=\"mono\" style=\"letter-spacing:0;text-transform:none\">ui · hooks: onSessionExit / onNeedsInput / onTaskMoved / onCronFired</span></h2>\n<div class=\"card row\">\n  <button onclick=\"yaam.guard(yaam.api.flash('flash from the kitchen sink'))\">flash()</button>\n  <button onclick=\"yaam.guard(yaam.api.notify('Kitchen sink', 'notify() lands in the bell popover'))\">notify()</button>\n  <button onclick=\"yaam.guard(yaam.api.logEvent('logEvent() lands in the Activity timeline'))\">logEvent()</button>\n  <span class=\"grow\"></span>\n  <span class=\"meta\">all four hooks append to the log below (hooks/log.js)</span>\n</div>\n<div class=\"card\"><div id=\"hookLog\"><span class=\"empty\">no hook events yet — exit a session, move a task, or let a schedule fire</span></div></div>\n\n<script>\n// YAAM addon view SDK.\n//\n// Inline it into your view with an @include marker inside a <script> block\n// (see toolkit/README.md) — resolved at install/pack time, because the\n// sandbox CSP forbids external resources; there is no <script src>.\n/*\n * It defines one global, `yaam`:\n *\n *   yaam.call('tasks.add', 'title', 'backlog', {...})  // raw dotted RPC → Promise\n *   yaam.api.tasks.add('title', 'backlog', {...})      // same, as a proxy tree\n *   yaam.onState(state => render(state))               // live snapshot pushes (~3s)\n *   yaam.banner('something went wrong')                // error strip (auto-hides)\n *   yaam.guard(promise)                                // await + banner on rejection\n *   yaam.esc(text) · yaam.ago(ts) · yaam.el(...)       // small view helpers\n *   yaam.confirm(button, () => doIt())                 // two-click confirm (no modals!)\n *\n * Every api method needs its permission granted in the Addons view; denied\n * calls reject with `permission \"…\" not granted` — yaam.guard surfaces those.\n */\n'use strict'\nconst yaam = (() => {\n  let seq = 0\n  const pending = {}\n  const stateSubs = []\n  let lastState = null\n\n  function call(method, ...args){\n    return new Promise((resolve, reject) => {\n      const callId = 'sdk' + (++seq)\n      pending[callId] = { resolve, reject }\n      parent.postMessage({ type: 'yaam:call', callId, method, args }, '*')\n    })\n  }\n\n  window.addEventListener('message', e => {\n    const d = e.data\n    if (!d || typeof d !== 'object') return\n    if (d.type === 'yaam:result' && pending[d.callId]) {\n      d.error ? pending[d.callId].reject(new Error(d.error)) : pending[d.callId].resolve(d.result)\n      delete pending[d.callId]\n    }\n    if (d.type === 'yaam:state') {\n      lastState = d.state\n      for (const cb of stateSubs) { try { cb(d.state, d.denied) } catch (err) { console.error(err) } }\n    }\n  })\n\n  // yaam.api.tasks.add(...) → call('tasks.add', ...)\n  const api = new Proxy({}, {\n    get: (_t, ns) => new Proxy(() => {}, {\n      apply: (_f, _this, args) => call(String(ns), ...args),          // yaam.api.flash('hi')\n      get: (_t2, method) => (...args) => call(ns + '.' + String(method), ...args),\n    }),\n  })\n\n  function banner(msg){\n    let b = document.getElementById('yaam-banner')\n    if (!b) {\n      b = document.createElement('div')\n      b.id = 'yaam-banner'\n      document.body.prepend(b)\n    }\n    if (!msg) { b.style.display = 'none'; return }\n    b.textContent = /permission \"/.test(String(msg))\n      ? msg + ' — grant it in the Addons view, then retry.'\n      : String(msg)\n    b.style.display = 'block'\n    clearTimeout(banner._t)\n    banner._t = setTimeout(() => { b.style.display = 'none' }, 7000)\n  }\n\n  async function guard(promise, fallback){\n    try { return await promise } catch (e) { banner(e && e.message || e); return fallback }\n  }\n\n  const esc = t => String(t == null ? '' : t).replace(/[&<>\"]/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '\"': '&quot;' }[c]))\n  const ago = t => {\n    const s = (Date.now() - t) / 1000\n    return s < 90 ? 'just now' : s < 3600 ? Math.round(s / 60) + 'm ago' : s < 86400 ? Math.round(s / 3600) + 'h ago' : Math.round(s / 86400) + 'd ago'\n  }\n\n  // tiny DOM builder: el('button', {class:'primary', onclick: fn}, 'Run')\n  function el(tag, attrs, ...children){\n    const node = document.createElement(tag)\n    for (const [k, v] of Object.entries(attrs || {})) {\n      if (k.startsWith('on') && typeof v === 'function') node[k] = v\n      else if (k === 'style' && typeof v === 'object') Object.assign(node.style, v)\n      else node.setAttribute(k === 'class' ? 'class' : k, v)\n    }\n    for (const c of children.flat()) {\n      if (c == null) continue\n      node.appendChild(typeof c === 'string' ? document.createTextNode(c) : c)\n    }\n    return node\n  }\n\n  // modals are blocked in the sandbox — destructive actions confirm by\n  // arming the button: first click asks, second within 2.5s executes\n  function confirm(button, action, label){\n    if (button.dataset.armed && Date.now() - Number(button.dataset.armed) < 2500) {\n      delete button.dataset.armed\n      button.textContent = button.dataset.orig || button.textContent\n      action()\n      return\n    }\n    button.dataset.armed = String(Date.now())\n    button.dataset.orig = button.textContent\n    button.textContent = label || 'sure? click again'\n    setTimeout(() => {\n      if (button.dataset.armed) {\n        delete button.dataset.armed\n        button.textContent = button.dataset.orig\n      }\n    }, 2600)\n  }\n\n  function onState(cb){\n    stateSubs.push(cb)\n    if (lastState) cb(lastState)\n    parent.postMessage({ type: 'yaam:getState' }, '*')\n    return () => { const i = stateSubs.indexOf(cb); if (i >= 0) stateSubs.splice(i, 1) }\n  }\n\n  return { call, api, onState, state: () => lastState, banner, guard, esc, ago, el, confirm }\n})()\n\n'use strict'\nconst $ = id => document.getElementById(id)\nconst pretty = v => { try { return JSON.stringify(v, null, 2) } catch (e) { return String(v) } }\n\n// ---------- 1 · snapshot ----------\nlet snap = null\nyaam.onState(state => {\n  snap = state\n  if (!state) { $('snapshot').innerHTML = '<span class=\"empty\">state:read not granted — grant it in the Addons view</span>'; return }\n  $('snapshot').innerHTML =\n    `<div class=\"row\"><span class=\"chip\"><b>${state.sessions.length}</b> sessions</span>`\n    + `<span class=\"chip\"><b>${state.tasks.length}</b> tasks</span>`\n    + `<span class=\"chip\"><b>${state.templates.length}</b> templates</span>`\n    + `<span class=\"chip\"><b>${state.machines.length}</b> machines</span>`\n    + `<span class=\"chip\"><b>$${state.totals.cost}</b> spent</span>`\n    + `<span class=\"grow\"></span><span class=\"meta\">workspace: ${yaam.esc(state.workspace)}</span></div>`\n    + `<details style=\"margin-top:8px\"><summary>raw snapshot JSON</summary><pre>${yaam.esc(pretty(state))}</pre></details>`\n  renderSessions(); renderTasks(); renderTemplates(); renderCrons(); renderHookLog()\n})\n\n// ---------- 2 · sessions ----------\nasync function launch(){\n  const id = await yaam.guard(yaam.api.launchSession($('lCmd').value, $('lCwd').value, $('lName').value))\n  if (id) yaam.api.flash('launched ' + id).catch(() => {})\n}\nfunction renderSessions(){\n  const el = $('sessions')\n  el.innerHTML = ''\n  for (const s of (snap ? snap.sessions : []).slice(0, 8)) {\n    const card = yaam.el('div', { class: 'card sess row' },\n      yaam.el('span', { class: 'dot ' + (s.status === 'running' ? 'running' : s.status === 'needs' ? 'err' : 'on') }),\n      yaam.el('span', { class: 'nm' }, s.name),\n      yaam.el('span', { class: 'meta grow' }, `${s.status} · $${s.cost}${s.machineId ? ' · remote' : ''}${s.isolated ? ' · ⑂' : ''}`),\n      yaam.el('button', { onclick: async () => {\n        const out = await yaam.guard(yaam.api.sessions.readOutput(s.id, 15), '')\n        card.querySelector('pre')?.remove()\n        card.appendChild(yaam.el('pre', { style: { width: '100%' } }, out || '(no output)'))\n      } }, 'read output'),\n      yaam.el('button', { onclick: () => yaam.guard(yaam.api.sendToSession(s.id, 'hello from the kitchen sink')) }, 'send line'),\n      yaam.el('button', { onclick: () => yaam.guard(yaam.api.focusSession(s.id)) }, 'focus'),\n      yaam.el('button', { class: 'danger', onclick: ev => yaam.confirm(ev.target, () => yaam.guard(yaam.api.sessions.stop(s.id))) }, 'stop'),\n    )\n    el.appendChild(card)\n  }\n  if (!el.children.length) el.innerHTML = '<div class=\"empty\">no live sessions — launch one above</div>'\n}\n\n// ---------- 3 · tasks ----------\nasync function addTask(){\n  const mins = $('tWhen').value\n  const id = await yaam.guard(yaam.api.tasks.add($('tTitle').value, $('tCol').value, {\n    description: $('tDesc').value,\n    criteria: ['the session ran and exited cleanly'],\n    isolate: $('tIso').checked || undefined,\n    sessionMode: $('tMode').value || undefined,\n    scheduleAt: mins ? Date.now() + Number(mins) * 60000 : undefined,\n  }))\n  if (id && $('tStart').checked && !mins) await yaam.guard(yaam.api.tasks.start(id))\n}\nfunction renderTasks(){\n  const el = $('tasks')\n  el.innerHTML = ''\n  for (const t of (snap ? snap.tasks : []).slice(-8).reverse()) {\n    const card = yaam.el('div', { class: 'card task row' },\n      yaam.el('span', { class: 'pill ' + (t.col === 'done' ? 'done' : t.col === 'failed' ? 'failed' : t.col === 'review' ? 'warn' : 'mut') }, t.col),\n      yaam.el('span', { class: 'nm' }, t.title),\n      yaam.el('span', { class: 'meta grow' }, `${t.sessionMode}${t.isolate ? ' · ⑂' : ''}${t.scheduleAt ? ' · starts ' + new Date(t.scheduleAt).toLocaleTimeString() : ''}${t.watcherNote ? ' · ' + t.watcherNote.slice(0, 40) : ''}`),\n      yaam.el('button', { onclick: async () => {\n        const detail = await yaam.guard(yaam.api.tasks.get(t.id))\n        card.querySelector('pre')?.remove()\n        card.appendChild(yaam.el('pre', { style: { width: '100%' } }, pretty(detail)))\n      } }, 'get'),\n      t.col === 'backlog' ? yaam.el('button', { class: 'primary', onclick: () => yaam.guard(yaam.api.tasks.start(t.id)) }, '▶ start') : null,\n      t.col === 'review' ? yaam.el('button', { class: 'primary', onclick: () => yaam.guard(yaam.api.tasks.approve(t.id)) }, '✓ approve') : null,\n      t.col === 'review' ? yaam.el('button', { onclick: () => yaam.guard(yaam.api.tasks.reject(t.id, 'sent back by the kitchen sink — please double-check')) }, '↩ reject') : null,\n      yaam.el('button', { class: 'ghost danger', onclick: ev => yaam.confirm(ev.target, () => yaam.guard(yaam.api.tasks.remove(t.id)), '✕ sure?') }, '✕'),\n    )\n    el.appendChild(card)\n  }\n  if (!el.children.length) el.innerHTML = '<div class=\"empty\">no tasks — create one above</div>'\n}\n\n// ---------- 4 · templates ----------\nfunction renderTemplates(){\n  const el = $('templates')\n  const tpls = snap ? snap.templates : []\n  el.innerHTML = ''\n  for (const t of tpls) {\n    el.appendChild(yaam.el('div', { class: 'lrow' },\n      yaam.el('span', {}, t.name),\n      yaam.el('span', { class: 'meta grow' }, t.mode),\n      yaam.el('button', { onclick: () => yaam.guard(yaam.api.templates.run(t.id, 'say hello — kitchen-sink template run')) }, 'run with task'),\n    ))\n  }\n  if (!tpls.length) el.innerHTML = '<div class=\"empty\">no templates defined in this workspace (Templates view)</div>'\n}\n\n// ---------- 5 · schedules ----------\nasync function addSchedule(){\n  const mins = $('cAt').value\n  const spec = mins\n    ? { name: $('cName').value, at: Date.now() + Number(mins) * 60000 }\n    : { name: $('cName').value, schedule: $('cCron').value }\n  const res = await yaam.guard(yaam.api.schedules.add(spec))\n  if (typeof res === 'string') yaam.api.flash(res.slice(0, 76)).catch(() => {})\n}\nfunction renderCrons(){\n  const el = $('crons')\n  el.innerHTML = ''\n  for (const c of (snap ? snap.crons : [])) {\n    el.appendChild(yaam.el('div', { class: 'card row' },\n      yaam.el('span', { class: 'dot ' + (c.on ? 'on' : '') }),\n      yaam.el('span', { style: { fontWeight: 600, fontSize: '12px' } }, c.name),\n      yaam.el('span', { class: 'meta' }, (c.schedule || (c.at ? 'once ' + new Date(c.at).toLocaleTimeString() : '')) + ' · ' + c.action + ' · last: ' + c.last),\n      yaam.el('span', { class: 'meta grow' }, (c.runs || []).map(r => (r.ok ? '✓' : '✗')).join(' ') || 'no runs'),\n      yaam.el('button', { onclick: () => yaam.guard(yaam.api.schedules.toggle(c.name)) }, c.on ? 'pause' : 'resume'),\n      yaam.el('button', { class: 'ghost danger', onclick: ev => yaam.confirm(ev.target, () => yaam.guard(yaam.api.schedules.remove(c.name)), '✕ sure?') }, '✕'),\n    ))\n  }\n  if (!el.children.length) el.innerHTML = '<div class=\"empty\">no schedules — add the heartbeat above and watch §9 catch its onCronFired</div>'\n}\n\n// ---------- 6 · storage ----------\nasync function storKeys(){\n  const keys = await yaam.guard(yaam.api.storage.list(), [])\n  return 'keys: ' + (keys && keys.length ? keys.join(', ') : '(none)')\n}\nasync function storSet(){\n  let v = $('sVal').value\n  try { v = JSON.parse(v) } catch (e) { /* keep as plain string */ }\n  await yaam.guard(yaam.api.storage.set($('sKey').value, v))\n  $('sOut').textContent = await storKeys()\n}\nasync function storGet(){\n  const v = await yaam.guard(yaam.api.storage.get($('sKey').value))\n  $('sOut').textContent = pretty(v) + '\\n\\n' + await storKeys()\n}\nasync function storDel(){\n  await yaam.guard(yaam.api.storage.remove($('sKey').value))\n  $('sOut').textContent = await storKeys()\n}\nstorKeys().then(t => { $('sOut').textContent = t })\n\n// ---------- 7 · http + secrets ----------\nasync function httpGo(){\n  const btn = $('hGo')\n  btn.disabled = true\n  try {\n    let headers\n    try { headers = JSON.parse($('hHead').value || '{}') } catch (e) { yaam.banner('headers must be JSON'); btn.disabled = false; return }\n    const res = await yaam.api.http.request($('hMethod').value, $('hUrl').value, { headers })\n    $('hOut').textContent = `HTTP ${res.status} · ${res.contentType}\\n\\n${res.text.slice(0, 4000)}`\n  } catch (e) {\n    $('hOut').textContent = '✗ ' + e.message\n  }\n  btn.disabled = false\n}\nyaam.guard(yaam.api.secrets.list(), null).then(list => {\n  $('secretsLine').textContent = list\n    ? 'secrets: ' + list.map(s => `${s.name} ${s.set ? '● set' : '○ unset'}`).join(' · ') + ' — values live in the OS keychain; set them in the Addons view'\n    : 'secrets: grant the \"secrets\" scope to list slots'\n})\n\n// ---------- 8 · agent ----------\nasync function wake(){\n  const msg = $('aMsg').value.trim()\n  if (!msg) return\n  $('aMsg').value = ''\n  const chat = $('chat')\n  chat.appendChild(yaam.el('div', { class: 'bubble you' }, msg))\n  const btn = $('aGo')\n  btn.disabled = true\n  btn.innerHTML = '<span class=\"spin\">✳</span> thinking…'\n  const reply = await yaam.guard(yaam.api.agent.wake(msg), '(agent unavailable)')\n  chat.appendChild(yaam.el('div', { class: 'bubble bot' }, String(reply)))\n  btn.disabled = false\n  btn.textContent = 'Wake agent'\n  chat.scrollTop = chat.scrollHeight\n}\n\n// ---------- 9 · hook log ----------\nasync function renderHookLog(){\n  const log = await yaam.guard(yaam.api.storage.get('hookLog'), null)\n  if (!log || !log.length) return\n  $('hookLog').innerHTML = log.slice(0, 20).map(x =>\n    `<div class=\"lrow\"><span class=\"meta\">${yaam.ago(x.at)}</span><span class=\"mono\" style=\"font-size:10.5px;color:var(--mut)\">${yaam.esc(JSON.stringify(x.event))}</span></div>`).join('')\n}\n</script></body></html>\n"
}
