{
  "manifest": 3,
  "name": "GitHub Issues",
  "version": "1.0.0",
  "icon": "🐙",
  "description": "Pulls open issues from a GitHub repo on a schedule into a review queue — add them to the board yourself, or let the addon's customizable triage agent decide which become tasks. Uses a keychain-stored token for private repos.",
  "author": "yaam",
  "hosts": [
    "api.github.com"
  ],
  "secrets": [
    {
      "name": "GITHUB_TOKEN",
      "label": "GitHub personal access token (repo read scope; optional for public repos)"
    }
  ],
  "permissions": [
    "state:read",
    "tasks",
    "schedules",
    "storage",
    "ui",
    "http",
    "secrets",
    "agent"
  ],
  "hooks": {
    "onCronFired": "// (input = { name, kind }, api) — sync new GitHub issues when our schedule\n// fires. New (unseen) open issues land in the review queue; in auto mode the\n// triage agent is woken with them instead and decides which become tasks.\nif (input.name !== 'github-issues-sync') return\n\nconst cfg = (await api.storage.get('config')) || {}\nif (!cfg.owner || !cfg.repo) return\n\n// only send the Authorization header when a token is actually stored —\n// {{secret:…}} on an unset secret is a hard error by design\nconst secrets = await api.secrets.list()\nconst hasToken = secrets.some(s => s.name === 'GITHUB_TOKEN' && s.set)\nconst headers = { accept: 'application/vnd.github+json' }\nif (hasToken) headers.authorization = 'Bearer {{secret:GITHUB_TOKEN}}'\n\nconst labels = cfg.labels ? '&labels=' + encodeURIComponent(cfg.labels) : ''\nconst res = await api.http.request('GET',\n  `https://api.github.com/repos/${cfg.owner}/${cfg.repo}/issues?state=open&per_page=50&sort=created&direction=desc${labels}`,\n  { headers })\nif (res.status !== 200) {\n  await api.logEvent(`GitHub sync failed: HTTP ${res.status}`)\n  return\n}\n\nconst seen = (await api.storage.get('seen')) || []\nconst queue = (await api.storage.get('queue')) || []\nconst fresh = JSON.parse(res.text)\n  .filter(i => !i.pull_request) // the issues endpoint returns PRs too\n  .filter(i => !seen.includes(i.number) && !queue.some(q => q.number === i.number))\n  .map(i => ({\n    number: i.number,\n    title: i.title,\n    body: (i.body || '').slice(0, 2000),\n    labels: (i.labels || []).map(l => l.name),\n    url: i.html_url,\n    at: Date.now(),\n  }))\n\nawait api.storage.set('lastSync', { at: Date.now(), found: fresh.length, status: res.status })\nif (!fresh.length) return\n\nawait api.storage.set('queue', [...queue, ...fresh].slice(-100))\n\nif (cfg.auto) {\n  // auto mode: the triage agent reads the batch and files board tasks per its\n  // instructions (customize them in this addon's chat)\n  await api.agent.wake('New GitHub issues arrived — triage them per your instructions:\\n\\n'\n    + JSON.stringify(fresh.map(f => ({ number: f.number, title: f.title, labels: f.labels, body: f.body.slice(0, 400) })), null, 2))\n} else {\n  await api.notify('GitHub Issues', `${fresh.length} new issue(s) queued — review them in the GitHub Issues tab`)\n}\n"
  },
  "agent": {
    "system": "You are the triage officer for a GitHub-issues → task-board pipeline. When woken with a batch of new issues (JSON), decide for each one whether it becomes a board task.\n\nDefault policy (the user can refine this in the addon's Customize chat):\n- File a task for concrete, actionable issues: bugs with reproduction details, small well-scoped features, chores.\n- Skip questions, discussions, duplicates of queued/board work (check get_state first), and anything labelled `wontfix`, `duplicate`, or `question`.\n\nFor each issue you accept:\n1. Create the task with add_task — title `#<number> · <issue title>`, the issue body (plus its URL) as the description, and 1-3 verifiable acceptance criteria you derive from the issue. Use the `cwd` from storage key `config` (field `cwd`) when set. Do NOT start tasks yourself unless storage `config.autostart` is true.\n2. Remove the issue from the storage `queue` (match by `number`) and append its number to storage `seen`.\n\nFor each issue you skip: also move its number from `queue` to `seen`, and keep a one-line reason in storage `triageLog` (array, newest first, cap 50).\n\nFinish with a short summary: how many filed, how many skipped, why.\n"
  },
  "html": "<!DOCTYPE html><html><head><style>\nbody{margin:0;background:#0A0B0F;color:#E7E9F0;font-family:'IBM Plex Sans',system-ui,sans-serif;padding:22px;max-width:860px}\nh1{font-size:15px;margin:0 0 4px;display:flex;gap:8px;align-items:center}\nsmall{color:#8B93A1}\nh2{font-size:10.5px;letter-spacing:.5px;color:#8B93A1;margin:22px 0 8px;text-transform:uppercase}\n.card{background:#12151C;border:1px solid #1a1e26;border-radius:10px;padding:12px 14px;margin-bottom:8px}\n.row{display:flex;gap:8px;align-items:center;flex-wrap:wrap}\ninput{background:#0A0B0F;border:1px solid #2a2f3a;border-radius:7px;color:#E7E9F0;font-size:11.5px;padding:6px 9px;outline:none}\nbutton{background:transparent;border:1px solid #2a2f3a;border-radius:7px;color:#E7E9F0;font-size:11.5px;padding:6px 12px;cursor:pointer}\nbutton:hover{border-color:#F5C451;color:#F5C451}\nbutton.primary{border-color:rgba(61,220,151,.5);color:#3DDC97}\nlabel{font-size:10.5px;color:#8B93A1}\n.chk{display:flex;gap:6px;align-items:center;font-size:11.5px;color:#8B93A1;cursor:pointer}\n.iss{display:flex;gap:10px;align-items:flex-start}\n.iss b{font-size:12.5px}\n.iss .body{font-size:11.5px;color:#8B93A1;margin-top:3px;line-height:1.45;max-height:54px;overflow:hidden}\n.lbl{font-family:'JetBrains Mono',monospace;font-size:9.5px;border:1px solid #2a2f3a;border-radius:4px;padding:1px 6px;color:#8B93A1;margin-left:6px}\n.mono{font-family:'JetBrains Mono',monospace;font-size:10.5px;color:#8B93A1}\n.dot{width:7px;height:7px;border-radius:50%;display:inline-block;margin-right:5px;background:#3a4150}\n.dot.on{background:#3DDC97}\n.empty{color:#5a6170;font-size:12px;padding:6px 0}\na{color:#F5C451;text-decoration:none;font-size:11px}\n</style></head><body>\n<h1>🐙 GitHub Issues</h1>\n<small>open issues → review queue → board tasks · fetched on a schedule with a keychain-stored token</small>\n\n<h2>Repository</h2>\n<div class=\"card\">\n  <div class=\"row\">\n    <input id=\"owner\" placeholder=\"owner\" style=\"width:130px\">\n    <span style=\"color:#5a6170\">/</span>\n    <input id=\"repo\" placeholder=\"repo\" style=\"width:170px\">\n    <input id=\"labels\" placeholder=\"labels filter (comma-sep, optional)\" style=\"width:210px\">\n    <input id=\"cwd\" placeholder=\"workdir for tasks (optional)\" style=\"flex:1;min-width:160px\">\n    <button class=\"primary\" onclick=\"saveCfg()\">Save</button>\n  </div>\n  <div class=\"row\" style=\"margin-top:10px\">\n    <span class=\"mono\"><span id=\"tokDot\" class=\"dot\"></span><span id=\"tokTxt\">token…</span></span>\n    <span style=\"flex:1\"></span>\n    <label class=\"chk\"><input type=\"checkbox\" id=\"auto\"> auto-triage new issues (the addon's agent files the tasks)</label>\n    <label class=\"chk\"><input type=\"checkbox\" id=\"autostart\"> agent may also start them</label>\n  </div>\n</div>\n\n<h2>Sync</h2>\n<div class=\"card row\">\n  <button id=\"schedBtn\" onclick=\"toggleSchedule()\">…</button>\n  <span class=\"mono\">every 30 min while enabled</span>\n  <span style=\"flex:1\"></span>\n  <span id=\"lastSync\" class=\"mono\"></span>\n  <button onclick=\"syncNow()\">Sync now</button>\n</div>\n\n<h2>Queue — new issues awaiting review</h2>\n<div id=\"queue\"></div>\n\n<h2>Agent triage log</h2>\n<div id=\"tri\" class=\"card mono\" style=\"max-height:130px;overflow-y:auto\"></div>\n\n<script>\n'use strict'\nlet seq = 0\nconst pending = {}\nfunction call(method, ...args){\n  return new Promise((resolve, reject) => {\n    const callId = 'c' + (++seq)\n    pending[callId] = { resolve, reject }\n    parent.postMessage({ type: 'yaam:call', callId, method, args }, '*')\n  })\n}\nwindow.addEventListener('message', e => {\n  const d = e.data\n  if (d && d.type === 'yaam:result' && pending[d.callId]) {\n    d.error ? pending[d.callId].reject(new Error(d.error)) : pending[d.callId].resolve(d.result)\n    delete pending[d.callId]\n  }\n  if (d && d.type === 'yaam:state') refresh()\n})\nconst esc = t => String(t == null ? '' : t).replace(/[&<>\"]/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','\"':'&quot;'}[c]))\n\nlet cfg = {}\nasync function load(){\n  cfg = (await call('storage.get', 'config')) || {}\n  document.getElementById('owner').value = cfg.owner || ''\n  document.getElementById('repo').value = cfg.repo || ''\n  document.getElementById('labels').value = cfg.labels || ''\n  document.getElementById('cwd').value = cfg.cwd || ''\n  document.getElementById('auto').checked = !!cfg.auto\n  document.getElementById('autostart').checked = !!cfg.autostart\n  document.getElementById('schedBtn').textContent = cfg.schedOn ? 'Disable schedule' : 'Enable schedule'\n  try {\n    const secrets = await call('secrets.list')\n    const tok = secrets.find(s => s.name === 'GITHUB_TOKEN')\n    document.getElementById('tokDot').className = 'dot' + (tok && tok.set ? ' on' : '')\n    document.getElementById('tokTxt').textContent = tok && tok.set ? 'GITHUB_TOKEN set (keychain)' : 'no token — public repos only · set it in Addons → GitHub Issues'\n  } catch (e) {\n    document.getElementById('tokTxt').textContent = 'grant the \"secrets\" scope to check token status'\n  }\n  refresh()\n}\nasync function saveCfg(){\n  cfg = { ...cfg,\n    owner: document.getElementById('owner').value.trim(),\n    repo: document.getElementById('repo').value.trim(),\n    labels: document.getElementById('labels').value.trim(),\n    cwd: document.getElementById('cwd').value.trim(),\n    auto: document.getElementById('auto').checked,\n    autostart: document.getElementById('autostart').checked,\n  }\n  await call('storage.set', 'config', cfg)\n  await call('flash', 'saved')\n}\nasync function toggleSchedule(){\n  if (cfg.schedOn) {\n    await call('schedules.remove', 'github-issues-sync')\n    cfg.schedOn = false\n  } else {\n    await saveCfg()\n    if (!cfg.owner || !cfg.repo) { await call('flash', 'set owner/repo first'); return }\n    await call('schedules.add', { name: 'github-issues-sync', schedule: '*/30 * * * *' })\n    cfg.schedOn = true\n  }\n  await call('storage.set', 'config', cfg)\n  document.getElementById('schedBtn').textContent = cfg.schedOn ? 'Disable schedule' : 'Enable schedule'\n}\n\nasync function syncNow(){\n  await saveCfg()\n  if (!cfg.owner || !cfg.repo) { await call('flash', 'set owner/repo first'); return }\n  let headers = { accept: 'application/vnd.github+json' }\n  try {\n    const secrets = await call('secrets.list')\n    if (secrets.some(s => s.name === 'GITHUB_TOKEN' && s.set)) headers.authorization = 'Bearer {{secret:GITHUB_TOKEN}}'\n  } catch (e) { /* secrets scope not granted — try anonymously */ }\n  const labels = cfg.labels ? '&labels=' + encodeURIComponent(cfg.labels) : ''\n  let res\n  try {\n    res = await call('http.request', 'GET',\n      'https://api.github.com/repos/' + cfg.owner + '/' + cfg.repo + '/issues?state=open&per_page=50&sort=created&direction=desc' + labels,\n      { headers })\n  } catch (e) { await call('flash', String(e.message || e).slice(0, 76)); return }\n  if (res.status !== 200) { await call('flash', 'GitHub replied HTTP ' + res.status); return }\n  const seen = (await call('storage.get', 'seen')) || []\n  const queue = (await call('storage.get', 'queue')) || []\n  const fresh = JSON.parse(res.text)\n    .filter(i => !i.pull_request)\n    .filter(i => seen.indexOf(i.number) === -1 && !queue.some(q => q.number === i.number))\n    .map(i => ({ number: i.number, title: i.title, body: (i.body || '').slice(0, 2000), labels: (i.labels || []).map(l => l.name), url: i.html_url, at: Date.now() }))\n  await call('storage.set', 'queue', queue.concat(fresh).slice(-100))\n  await call('storage.set', 'lastSync', { at: Date.now(), found: fresh.length, status: res.status })\n  await call('flash', fresh.length + ' new issue(s)')\n  if (fresh.length && cfg.auto) {\n    await call('agent.wake', 'New GitHub issues arrived — triage them per your instructions:\\n\\n'\n      + JSON.stringify(fresh.map(f => ({ number: f.number, title: f.title, labels: f.labels, body: f.body.slice(0, 400) })), null, 2))\n  }\n  refresh()\n}\n\nasync function addToBoard(number){\n  const queue = (await call('storage.get', 'queue')) || []\n  const it = queue.find(q => q.number === number)\n  if (!it) return\n  await call('tasks.add', ('#' + it.number + ' · ' + it.title).slice(0, 120), 'backlog', {\n    description: it.body + '\\n\\n' + it.url,\n    cwd: cfg.cwd || undefined,\n  })\n  await dismiss(number, true)\n  await call('flash', 'task filed for #' + number)\n}\nasync function dismiss(number, silent){\n  const queue = (await call('storage.get', 'queue')) || []\n  const seen = (await call('storage.get', 'seen')) || []\n  await call('storage.set', 'queue', queue.filter(q => q.number !== number))\n  if (seen.indexOf(number) === -1) await call('storage.set', 'seen', seen.concat([number]).slice(-500))\n  if (!silent) refresh(); else refresh()\n}\n\nasync function refresh(){\n  const queue = (await call('storage.get', 'queue')) || []\n  const el = document.getElementById('queue')\n  el.innerHTML = ''\n  for (const it of queue.slice().reverse()) {\n    const d = document.createElement('div')\n    d.className = 'card iss'\n    d.innerHTML = '<div style=\"flex:1;min-width:0\"><b>#' + it.number + ' · ' + esc(it.title) + '</b>'\n      + it.labels.map(l => '<span class=\"lbl\">' + esc(l) + '</span>').join('')\n      + '<div class=\"body\">' + esc(it.body.slice(0, 240)) + '</div>'\n      + '<a href=\"' + esc(it.url) + '\" target=\"_blank\">' + esc(it.url) + '</a></div>'\n    const add = document.createElement('button'); add.className = 'primary'; add.textContent = 'Add to board'; add.onclick = () => addToBoard(it.number)\n    const dis = document.createElement('button'); dis.textContent = 'Dismiss'; dis.onclick = () => dismiss(it.number)\n    d.appendChild(add); d.appendChild(dis)\n    el.appendChild(d)\n  }\n  if (!queue.length) el.innerHTML = '<div class=\"empty\">queue is empty — enable the schedule or hit Sync now</div>'\n  const last = await call('storage.get', 'lastSync')\n  document.getElementById('lastSync').textContent = last ? 'last sync ' + new Date(last.at).toLocaleTimeString() + ' · +' + last.found : 'never synced'\n  const tri = (await call('storage.get', 'triageLog')) || []\n  document.getElementById('tri').innerHTML = tri.length ? tri.map(t => '<div>' + esc(t) + '</div>').join('') : '<span class=\"empty\">agent has not triaged anything yet</span>'\n}\nload()\nparent.postMessage({ type: 'yaam:getState' }, '*')\n</script></body></html>\n"
}
