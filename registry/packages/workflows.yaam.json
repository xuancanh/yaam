{
  "manifest": 3,
  "name": "Workflows",
  "version": "2.0.0",
  "icon": "⛓",
  "description": "Task workflows as state machines — every step is a board-task spec with on-done / on-fail transitions, so runs branch into remediation steps, loop back for visit-capped retries, and halt where you choose. Drag-and-drop editor, cron triggers, and a per-run path history.",
  "author": "yaam",
  "permissions": [
    "state:read",
    "tasks",
    "schedules",
    "storage",
    "ui"
  ],
  "hooks": {
    "onTaskMoved": "// (input = { taskId, title, col, from }, api) — a board task changed column.\n// Workflows are STATE MACHINES: if this task is the active step of a running\n// machine, take the step's transition — onDone when the task reached done,\n// onFail when it failed. No transition = the machine halts there (done/failed).\n// Loops are legal; each step may run at most `maxVisits` (default 3) per run.\nif (input.col !== 'done' && input.col !== 'failed') return\n\nconst runs = (await api.storage.get('runs')) || []\nconst run = runs.find(r => r.status === 'running' && r.taskId === input.taskId)\nif (!run) return\n\nconst workflows = (await api.storage.get('workflows')) || []\nconst wf = workflows.find(w => w.id === run.wfId)\nconst node = wf && wf.nodes.find(n => n.id === run.current)\n\nconst outcome = input.col === 'done' ? 'done' : 'failed'\nconst last = run.path[run.path.length - 1]\nif (last && last.taskId === input.taskId) last.outcome = outcome\n\nconst nextId = node ? (outcome === 'done' ? node.onDone : node.onFail) : null\nconst next = nextId && wf ? wf.nodes.find(n => n.id === nextId) : null\n\nconst halt = async (status, why) => {\n  run.status = status\n  run.current = null\n  run.taskId = null\n  run.finishedAt = Date.now()\n  await api.storage.set('runs', runs)\n  await api.notify(status === 'done' ? 'Workflow finished' : 'Workflow failed',\n    `\"${run.wfName}\" — ${why}`)\n}\n\nif (!next) {\n  // terminal state: done with no onDone = success; failed with no onFail = failure\n  await halt(outcome, outcome === 'done'\n    ? `halted after \"${input.title}\" (terminal step)`\n    : `step \"${input.title}\" failed with no failure transition`)\n  return\n}\n\nconst visits = (run.visits[next.id] || 0) + 1\nconst cap = Number(next.maxVisits) > 0 ? Number(next.maxVisits) : 3\nif (visits > cap) {\n  await halt('failed', `step \"${next.title}\" exceeded its ${cap}-visit cap — breaking the loop`)\n  return\n}\n\n// take the transition: launch the next step's task and move the machine there\nconst taskId = await api.tasks.add(next.title, 'backlog', {\n  description: [\n    `[workflow \"${wf.name}\" · run ${run.id} · step ${next.id} · visit ${visits}]`,\n    outcome === 'failed' ? `You are the failure branch: the previous step \"${node.title}\" FAILED — diagnose and remedy before/while doing your own work.` : '',\n    next.description || '',\n  ].filter(Boolean).join('\\n\\n'),\n  criteria: next.criteria || [],\n  cwd: next.cwd || undefined,\n  isolate: next.isolate === true ? true : undefined,\n})\nawait api.tasks.start(taskId)\nrun.current = next.id\nrun.taskId = taskId\nrun.visits[next.id] = visits\nrun.path.push({ nodeId: next.id, title: next.title, taskId, outcome: 'running', at: Date.now(), via: outcome })\nawait api.storage.set('runs', runs)\nawait api.logEvent(`workflow \"${run.wfName}\": ${outcome === 'done' ? '✓' : '✗'} \"${input.title}\" → \"${next.title}\"${visits > 1 ? ' (visit ' + visits + ')' : ''}`)\n",
    "onCronFired": "// (input = { name, kind }, api) — a schedule fired. Workflow triggers are\n// schedules named \"wf-<workflow id>\" armed from the Workflows tab. Workflows\n// are STATE MACHINES: one active step at a time; each step declares where the\n// machine goes on done / on fail (loops allowed, capped per run). Firing one\n// starts a run at the workflow's start step.\nif (!String(input.name || '').startsWith('wf-')) return\n\nconst wfId = String(input.name).slice(3)\nconst workflows = (await api.storage.get('workflows')) || []\nconst wf = workflows.find(w => w.id === wfId)\nif (!wf || !Array.isArray(wf.nodes) || !wf.nodes.length) return\n\n// one running machine per workflow — a slow pipeline must not stack on itself\nconst runs = (await api.storage.get('runs')) || []\nif (runs.some(r => r.wfId === wf.id && r.status === 'running')) {\n  await api.logEvent(`workflow \"${wf.name}\" skipped a cron trigger — previous run still going`)\n  return\n}\n\nconst start = wf.nodes.find(n => n.id === wf.start) || wf.nodes[0]\nconst run = {\n  id: 'run' + Date.now().toString(36),\n  wfId: wf.id, wfName: wf.name, startedAt: Date.now(), status: 'running',\n  trigger: 'cron', current: start.id, taskId: null,\n  visits: {}, path: [],\n}\n\nconst taskId = await api.tasks.add(start.title, 'backlog', {\n  description: [`[workflow \"${wf.name}\" · run ${run.id} · step ${start.id}]`, start.description || ''].filter(Boolean).join('\\n\\n'),\n  criteria: start.criteria || [],\n  cwd: start.cwd || undefined,\n  isolate: start.isolate === true ? true : undefined,\n})\nawait api.tasks.start(taskId)\nrun.taskId = taskId\nrun.visits[start.id] = 1\nrun.path.push({ nodeId: start.id, title: start.title, taskId, outcome: 'running', at: Date.now() })\n\nawait api.storage.set('runs', [run, ...runs].slice(0, 30))\nawait api.notify('Workflow started', `\"${wf.name}\" — entered step \"${start.title}\"`)\n"
  },
  "html": "<!DOCTYPE html><html><head><style>\n:root{--bg:#0A0B0F;--panel:#12151C;--panel2:#0D0F14;--line:#1a1e26;--line2:#23272F;--text:#E7E9F0;--mut:#8B93A1;--dim:#5a6170;--acc:#F5C451;--green:#3DDC97;--red:#FF5C5C;--amber:#FFB020}\n*{box-sizing:border-box}\nbody{margin:0;background:var(--bg);color:var(--text);font-family:'IBM Plex Sans',system-ui,sans-serif;display:flex;height:100vh;overflow:hidden;font-size:13px}\n.mono{font-family:'JetBrains Mono',monospace}\nh2{font-size:10px;letter-spacing:.6px;color:var(--dim);margin:0 0 8px;text-transform:uppercase;font-weight:600}\nbutton{background:transparent;border:1px solid var(--line2);border-radius:8px;color:var(--text);font-size:11.5px;padding:6px 13px;cursor:pointer;font-family:inherit;transition:border-color .12s,color .12s,background .12s}\nbutton:hover{border-color:var(--acc);color:var(--acc)}\nbutton:disabled{opacity:.4;cursor:default;pointer-events:none}\nbutton.primary{border-color:rgba(61,220,151,.45);color:var(--green)}\nbutton.primary:hover{background:rgba(61,220,151,.08)}\nbutton.danger:hover{border-color:var(--red);color:var(--red)}\nbutton.ghost{border-color:transparent;color:var(--mut);padding:6px 8px}\nbutton.ghost:hover{color:var(--acc)}\nbutton.linkdone{border-color:rgba(61,220,151,.4);color:var(--green);font-size:10.5px;padding:5px 9px}\nbutton.linkfail{border-color:rgba(255,92,92,.4);color:var(--red);font-size:10.5px;padding:5px 9px}\ninput,textarea,select{background:var(--bg);border:1px solid var(--line2);border-radius:8px;color:var(--text);font-size:11.5px;padding:6px 9px;outline:none;font-family:inherit;width:100%}\ninput:focus,textarea:focus{border-color:rgba(245,196,81,.45)}\n\n#side{width:232px;border-right:1px solid var(--line);padding:16px 12px;display:flex;flex-direction:column;gap:4px;overflow-y:auto;flex:none}\n#side .brand{font-size:14px;font-weight:600;display:flex;gap:8px;align-items:center;padding:0 4px}\n#side .tag{font-size:10.5px;color:var(--dim);padding:0 4px;margin-bottom:12px}\n.wf{background:transparent;border:1px solid transparent;border-radius:9px;padding:9px 10px;cursor:pointer;display:flex;gap:8px;align-items:center}\n.wf:hover{background:var(--panel)}\n.wf.sel{background:var(--panel);border-color:var(--line2)}\n.wf .nm{flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-weight:600;font-size:12.5px}\n.wf .meta{font-size:9.5px;color:var(--dim)}\n.dot{width:7px;height:7px;border-radius:50%;background:var(--line2);flex:none}\n.dot.running{background:var(--amber);animation:pulse 1.1s ease-in-out infinite}\n.dot.done{background:var(--green)}.dot.failed{background:var(--red)}\n@keyframes pulse{50%{opacity:.35}}\n.cron-chip{font-family:'JetBrains Mono',monospace;font-size:8.5px;color:var(--acc);border:1px solid rgba(245,196,81,.3);border-radius:4px;padding:1px 4px}\n\n#main{flex:1;display:flex;flex-direction:column;min-width:0}\n#bar{display:flex;gap:8px;align-items:center;padding:11px 16px;border-bottom:1px solid var(--line);flex:none;flex-wrap:wrap}\n#wfName{background:transparent;border:1px solid transparent;font-size:14.5px;font-weight:600;width:190px;padding:4px 8px}\n#wfName:hover,#wfName:focus{border-color:var(--line2)}\n.sep{width:1px;height:22px;background:var(--line);margin:0 2px}\n#linkHint{font-size:11px;display:none;align-items:center;gap:6px}\n\n#canvasWrap{flex:1;position:relative;overflow:auto;background-image:radial-gradient(circle,#161a22 1px,transparent 1px);background-size:22px 22px}\nsvg{display:block}\n.node{cursor:grab}\n.node rect.body{fill:var(--panel);stroke:var(--line2);stroke-width:1.2}\n.node.sel rect.body{stroke:var(--acc);filter:drop-shadow(0 0 6px rgba(245,196,81,.25))}\n.node.linksrc rect.body{stroke:var(--acc);stroke-dasharray:4 3}\n.node rect.stripe{fill:var(--line2)}\n.node.running rect.stripe{fill:var(--amber)}\n.node.done rect.stripe{fill:var(--green)}\n.node.failed rect.stripe{fill:var(--red)}\n.node text{fill:var(--text);font-size:12px;font-weight:600;pointer-events:none;font-family:'IBM Plex Sans',system-ui}\n.node .sub{fill:var(--mut);font-size:9.5px;font-weight:400}\n.node .startbadge{fill:var(--acc);font-size:9px;font-weight:700}\n.edge{stroke-width:1.7;fill:none;cursor:pointer}\n.edge.done{stroke:rgba(61,220,151,.65);marker-end:url(#arrG)}\n.edge.fail{stroke:rgba(255,92,92,.6);stroke-dasharray:6 4;marker-end:url(#arrR)}\n.edge:hover{stroke-width:2.6}\n#ghost{stroke-width:1.4;stroke-dasharray:5 4;fill:none;pointer-events:none}\n\n#editor{position:absolute;right:14px;top:14px;width:268px;background:var(--panel);border:1px solid var(--line2);border-radius:12px;padding:14px;display:none;flex-direction:column;gap:7px;box-shadow:0 14px 34px rgba(0,0,0,.55)}\n#editor label{font-size:9.5px;color:var(--dim);letter-spacing:.4px;text-transform:uppercase;font-weight:600}\n.chk{display:flex;gap:7px;align-items:center;font-size:11.5px;color:var(--mut);cursor:pointer}\n.chk input{width:auto;accent-color:var(--acc)}\n.trow{display:flex;gap:6px;align-items:center;font-size:11px;color:var(--mut)}\n.trow b{font-size:10.5px}\n\n#bottom{border-top:1px solid var(--line);padding:12px 16px;max-height:240px;overflow-y:auto;flex:none}\n.run{background:var(--panel);border:1px solid var(--line);border-radius:9px;padding:8px 12px;margin-bottom:6px;cursor:pointer}\n.run .head{display:flex;gap:10px;align-items:center}\n.run .st{font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;border-radius:5px;padding:1px 8px;border:1px solid}\n.st.running{color:var(--amber);border-color:rgba(255,176,32,.4)}\n.st.done{color:var(--green);border-color:rgba(61,220,151,.4)}\n.st.failed{color:var(--red);border-color:rgba(255,92,92,.4)}\n.run .meta{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--dim)}\n.run .path{display:none;margin-top:8px;border-top:1px solid var(--line);padding-top:7px;flex-wrap:wrap;gap:4px;align-items:center}\n.run.open .path{display:flex}\n.step{display:inline-flex;gap:6px;align-items:center;background:var(--panel2);border:1px solid var(--line2);border-radius:6px;padding:3px 8px;font-size:10.5px}\n.via{font-size:10px;color:var(--dim)}\n.via.done{color:var(--green)}.via.failed{color:var(--red)}\n.empty{color:var(--dim);font-size:12px;padding:8px 2px}\n#banner{display:none;background:rgba(255,92,92,.08);border-bottom:1px solid rgba(255,92,92,.3);color:var(--red);font-size:11.5px;padding:7px 16px}\n#onboard{position:absolute;inset:0;display:flex;align-items:center;justify-content:center}\n#onboard .card{background:var(--panel);border:1px solid var(--line2);border-radius:14px;padding:28px 32px;max-width:440px;text-align:center}\n#onboard h3{margin:0 0 8px;font-size:15px}\n#onboard p{color:var(--mut);font-size:12px;line-height:1.6;margin:0 0 16px}\n.hintline{font-size:10px;color:var(--dim);padding:5px 16px;border-bottom:1px solid var(--line)}\n.hintline b.g{color:var(--green)}.hintline b.r{color:var(--red)}\nkbd{font-family:'JetBrains Mono',monospace;font-size:9px;border:1px solid var(--line2);border-radius:4px;padding:0 4px;color:var(--mut)}\n</style></head><body>\n<div id=\"side\">\n  <div class=\"brand\">⛓ Workflows</div>\n  <div class=\"tag\">state machines over board tasks</div>\n  <h2 style=\"padding:0 4px\">Machines</h2>\n  <div id=\"wfList\"></div>\n  <button class=\"ghost\" style=\"text-align:left\" onclick=\"addWorkflow()\">＋ New workflow</button>\n</div>\n<div id=\"main\">\n  <div id=\"banner\"></div>\n  <div id=\"bar\">\n    <input id=\"wfName\" onchange=\"renameWf(this.value)\" spellcheck=\"false\">\n    <button class=\"primary\" id=\"runBtn\" onclick=\"runNow()\">▶ Run now</button>\n    <button onclick=\"addNode()\">＋ Step</button>\n    <span id=\"linkHint\"></span>\n    <span style=\"flex:1\"></span>\n    <select id=\"cronSel\" onchange=\"cronPreset()\" style=\"width:150px\">\n      <option value=\"\">no cron trigger</option>\n      <option value=\"0 * * * *\">hourly, on the hour</option>\n      <option value=\"0 6 * * *\">daily · 06:00</option>\n      <option value=\"0 6 * * 1\">Mondays · 06:00</option>\n      <option value=\"custom\">custom…</option>\n    </select>\n    <input id=\"cron\" class=\"mono\" placeholder=\"*/30 * * * *\" style=\"width:110px;display:none\">\n    <button id=\"cronBtn\" onclick=\"toggleCron()\">Arm</button>\n    <div class=\"sep\"></div>\n    <button class=\"danger\" id=\"delWf\" onclick=\"removeWorkflow()\">Delete</button>\n  </div>\n  <div class=\"hintline\">one active step per run · select a step, then <b class=\"g\">on done →</b> / <b class=\"r\">on fail →</b> and click the target · loops allowed (visit-capped) · no transition = the machine halts there · <kbd>⌫</kbd> deletes · <kbd>Esc</kbd> cancels linking</div>\n  <div id=\"canvasWrap\">\n    <svg id=\"svg\" width=\"1600\" height=\"900\">\n      <defs>\n        <marker id=\"arrG\" viewBox=\"0 0 8 8\" refX=\"7\" refY=\"4\" markerWidth=\"7\" markerHeight=\"7\" orient=\"auto\"><path d=\"M0,0 L8,4 L0,8 z\" fill=\"#3DDC97\"/></marker>\n        <marker id=\"arrR\" viewBox=\"0 0 8 8\" refX=\"7\" refY=\"4\" markerWidth=\"7\" markerHeight=\"7\" orient=\"auto\"><path d=\"M0,0 L8,4 L0,8 z\" fill=\"#FF5C5C\"/></marker>\n      </defs>\n      <g id=\"edges\"></g><path id=\"ghost\" d=\"\"/><g id=\"nodes\"></g>\n    </svg>\n    <div id=\"editor\">\n      <label>Step title</label><input id=\"eTitle\">\n      <label>What the agent should do</label><textarea id=\"eDesc\" rows=\"4\" placeholder=\"clear instructions for a one-shot agent…\"></textarea>\n      <label>Acceptance criteria — one per line</label><textarea id=\"eCrit\" rows=\"3\" placeholder=\"tests pass&#10;docs updated\"></textarea>\n      <label>Working directory</label><input id=\"eCwd\" placeholder=\"(workspace default)\">\n      <div style=\"display:flex;gap:8px\">\n        <div style=\"flex:1\"><label>Max visits / run</label><input id=\"eMax\" type=\"number\" min=\"1\" max=\"9\" placeholder=\"3\"></div>\n        <div style=\"flex:1.4;display:flex;align-items:flex-end\"><div class=\"chk\"><input type=\"checkbox\" id=\"eIso\"><span>worktree ⑂</span></div></div>\n      </div>\n      <label style=\"margin-top:3px\">Transitions</label>\n      <div class=\"trow\"><b style=\"color:var(--green)\">on done</b><span id=\"tDone\" style=\"flex:1\">— halt (success)</span><button class=\"linkdone\" onclick=\"linkFrom('done')\">set →</button><button class=\"ghost\" onclick=\"clearLink('onDone')\">✕</button></div>\n      <div class=\"trow\"><b style=\"color:var(--red)\">on fail</b><span id=\"tFail\" style=\"flex:1\">— halt (failure)</span><button class=\"linkfail\" onclick=\"linkFrom('fail')\">set →</button><button class=\"ghost\" onclick=\"clearLink('onFail')\">✕</button></div>\n      <div style=\"display:flex;gap:6px;margin-top:5px\">\n        <button class=\"primary\" style=\"flex:1\" onclick=\"saveNode()\">Save</button>\n        <button onclick=\"setStart()\" title=\"the machine enters here\">▶ start</button>\n        <button class=\"danger\" onclick=\"deleteNode()\">✕</button>\n      </div>\n    </div>\n    <div id=\"onboard\" style=\"display:none\">\n      <div class=\"card\">\n        <h3>⛓ Workflows are state machines</h3>\n        <p>Each step is a board-task spec. When its task finishes, the machine takes the <b style=\"color:var(--green)\">on&nbsp;done</b> or\n        <b style=\"color:var(--red)\">on&nbsp;fail</b> transition — so you can branch into remediation steps, loop back for retries\n        (visit-capped), and halt wherever you choose. Trigger runs by hand or on a cron.</p>\n        <button class=\"primary\" onclick=\"seedDemo()\">Create an example machine</button>\n        <button onclick=\"addWorkflow()\">Start empty</button>\n      </div>\n    </div>\n  </div>\n  <div id=\"bottom\">\n    <h2>Run history <span id=\"histCount\" class=\"mono\" style=\"color:var(--dim);text-transform:none;letter-spacing:0\"></span></h2>\n    <div id=\"runList\"></div>\n  </div>\n</div>\n<script>\n'use strict'\nlet seq = 0\nconst pending = {}\nfunction call(method, ...args){\n  return new Promise((resolve, reject) => {\n    const callId = 'c' + (++seq)\n    pending[callId] = { resolve, reject }\n    parent.postMessage({ type: 'yaam:call', callId, method, args }, '*')\n  })\n}\nwindow.addEventListener('message', e => {\n  const d = e.data\n  if (d && d.type === 'yaam:result' && pending[d.callId]) {\n    d.error ? pending[d.callId].reject(new Error(d.error)) : pending[d.callId].resolve(d.result)\n    delete pending[d.callId]\n  }\n  if (d && d.type === 'yaam:state') refreshRuns() // pushed ~3s — our poll tick\n})\nfunction banner(msg){\n  const b = document.getElementById('banner')\n  if (!msg) { b.style.display = 'none'; return }\n  b.textContent = /permission \"/.test(msg) ? msg + ' — grant it in the Addons view, then retry.' : msg\n  b.style.display = 'block'\n  setTimeout(() => { b.style.display = 'none' }, 6000)\n}\nconst esc = t => String(t == null ? '' : t).replace(/[&<>\"]/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','\"':'&quot;'}[c]))\nconst ago = t => { const s = (Date.now() - t) / 1000; return s < 90 ? 'just now' : s < 3600 ? Math.round(s / 60) + 'm ago' : s < 86400 ? Math.round(s / 3600) + 'h ago' : Math.round(s / 86400) + 'd ago' }\n\nlet workflows = [], runs = [], selWf = null, selNode = null, openRun = null\nlet linkSrc = null, linkKind = null // linking a transition: source node + 'done'|'fail'\nconst wf = () => workflows.find(w => w.id === selWf)\nconst nodeOf = id => { const w = wf(); return w && w.nodes.find(n => n.id === id) }\nconst save = () => call('storage.set', 'workflows', workflows).catch(e => banner(e.message))\n\nasync function load(){\n  try { workflows = (await call('storage.get', 'workflows')) || [] } catch (e) { banner(e.message); workflows = [] }\n  if (!selWf && workflows.length) selWf = workflows[0].id\n  render()\n  refreshRuns()\n}\n\n// live step status: from this workflow's newest run (fresh for 2 min after it ends)\nfunction liveStatus(){\n  const r = runs.find(x => x.wfId === selWf)\n  const map = {}\n  if (r && (r.status === 'running' || Date.now() - (r.finishedAt || r.startedAt) < 120000)) {\n    for (const p of r.path || []) map[p.nodeId] = p.outcome\n    if (r.status === 'running' && r.current) map[r.current] = 'running'\n  }\n  return map\n}\n\nfunction render(){\n  const w = wf()\n  const list = document.getElementById('wfList')\n  list.innerHTML = ''\n  for (const x of workflows) {\n    const running = runs.some(r => r.wfId === x.id && r.status === 'running')\n    const el = document.createElement('div')\n    el.className = 'wf' + (x.id === selWf ? ' sel' : '')\n    el.innerHTML = `<span class=\"dot${running ? ' running' : ''}\"></span><span class=\"nm\">${esc(x.name)}</span>`\n      + (x.cronOn ? `<span class=\"cron-chip\">${esc(x.cron)}</span>` : '')\n      + `<span class=\"meta\">${x.nodes.length}</span>`\n    el.onclick = () => { selWf = x.id; selNode = null; cancelLink(); render(); refreshRuns() }\n    list.appendChild(el)\n  }\n  document.getElementById('onboard').style.display = workflows.length ? 'none' : 'flex'\n  document.getElementById('bar').style.visibility = w ? 'visible' : 'hidden'\n  if (w) {\n    document.getElementById('wfName').value = w.name\n    const sel = document.getElementById('cronSel')\n    const preset = [...sel.options].some(o => o.value === w.cron) ? w.cron : (w.cron ? 'custom' : '')\n    sel.value = preset\n    const cronIn = document.getElementById('cron')\n    cronIn.style.display = preset === 'custom' ? '' : 'none'\n    cronIn.value = w.cron || ''\n    const btn = document.getElementById('cronBtn')\n    btn.textContent = w.cronOn ? '✓ Armed' : 'Arm'\n    btn.className = w.cronOn ? 'primary' : ''\n    const running = runs.some(r => r.wfId === w.id && r.status === 'running')\n    const runBtn = document.getElementById('runBtn')\n    runBtn.disabled = running || !w.nodes.length\n    runBtn.textContent = running ? '● Running…' : '▶ Run now'\n  }\n  const hint = document.getElementById('linkHint')\n  hint.style.display = linkSrc ? 'flex' : 'none'\n  if (linkSrc) {\n    hint.style.color = linkKind === 'done' ? 'var(--green)' : 'var(--red)'\n    hint.innerHTML = `◈ click the <b>on ${linkKind}</b> target — <kbd>Esc</kbd> cancels`\n  }\n  drawGraph()\n  drawEditor()\n}\n\nfunction edgePath(s, t){\n  const x1 = s.x + 172, y1 = s.y + 28, x2 = t.x, y2 = t.y + 28\n  if (x2 >= x1 - 20) return `M${x1},${y1} C${x1 + 46},${y1} ${x2 - 46},${y2} ${x2},${y2}`\n  // back-edge (a loop): swing underneath so it stays readable\n  const dip = Math.max(y1, y2) + 58\n  return `M${x1},${y1} C${x1 + 60},${dip} ${x2 - 60},${dip} ${x2},${y2}`\n}\n\nfunction drawGraph(){\n  const w = wf()\n  const gN = document.getElementById('nodes'), gE = document.getElementById('edges')\n  gN.innerHTML = ''; gE.innerHTML = ''\n  document.getElementById('ghost').setAttribute('d', '')\n  if (!w) return\n  const live = liveStatus()\n  const byId = {}\n  for (const n of w.nodes) byId[n.id] = n\n  for (const n of w.nodes) for (const [field, cls] of [['onDone', 'done'], ['onFail', 'fail']]) {\n    const t = n[field] && byId[n[field]]\n    if (!t) continue\n    const p = document.createElementNS('http://www.w3.org/2000/svg', 'path')\n    p.setAttribute('d', edgePath(n, t))\n    p.setAttribute('class', 'edge ' + cls)\n    const tt = document.createElementNS('http://www.w3.org/2000/svg', 'title')\n    tt.textContent = `${n.title} — on ${cls === 'done' ? 'done' : 'fail'} → ${t.title} (click to remove)`\n    p.appendChild(tt)\n    p.onclick = ev => { ev.stopPropagation(); n[field] = null; save(); render() }\n    gE.appendChild(p)\n  }\n  const start = w.start && byId[w.start] ? w.start : (w.nodes[0] && w.nodes[0].id)\n  for (const n of w.nodes) {\n    const st = live[n.id] || ''\n    const g = document.createElementNS('http://www.w3.org/2000/svg', 'g')\n    g.setAttribute('class', 'node' + (n.id === selNode ? ' sel' : '') + (n.id === linkSrc ? ' linksrc' : '') + (st ? ' ' + st : ''))\n    g.setAttribute('transform', `translate(${n.x},${n.y})`)\n    const bits = []\n    if ((n.criteria || []).length) bits.push(n.criteria.length + ' crit')\n    if (n.isolate) bits.push('⑂')\n    if (!n.onDone) bits.push('halts on ✓')\n    if (st && st !== 'pending') bits.push(st)\n    g.innerHTML = `<rect class=\"body\" width=\"172\" height=\"56\" rx=\"10\"/><rect class=\"stripe\" x=\"0\" y=\"0\" width=\"4\" height=\"56\" rx=\"2\"/>`\n      + (n.id === start ? `<text x=\"160\" y=\"15\" text-anchor=\"end\" class=\"startbadge\">▶ START</text>` : '')\n      + `<text x=\"14\" y=\"23\">${esc(n.title.slice(0, 19))}</text>`\n      + `<text x=\"14\" y=\"41\" class=\"sub\">${esc(bits.join(' · ') || 'new step')}</text>`\n    g.onmousedown = ev => startDrag(ev, n)\n    g.onclick = ev => { ev.stopPropagation(); clickNode(n) }\n    gN.appendChild(g)\n  }\n}\n\n// ---------- drag (grid snap) + transition ghost line ----------\nlet drag = null\nfunction startDrag(ev, n){ if (!linkSrc) drag = { n, dx: ev.clientX - n.x, dy: ev.clientY - n.y, moved: false } }\nwindow.addEventListener('mousemove', ev => {\n  if (linkSrc) {\n    const s = nodeOf(linkSrc)\n    if (s) {\n      const wrapEl = document.getElementById('canvasWrap')\n      const wrap = wrapEl.getBoundingClientRect()\n      const mx = ev.clientX - wrap.left + wrapEl.scrollLeft\n      const my = ev.clientY - wrap.top + wrapEl.scrollTop\n      const gh = document.getElementById('ghost')\n      gh.setAttribute('d', `M${s.x + 172},${s.y + 28} L${mx},${my}`)\n      gh.setAttribute('stroke', linkKind === 'done' ? '#3DDC97' : '#FF5C5C')\n    }\n  }\n  if (!drag) return\n  drag.moved = true\n  drag.n.x = Math.max(0, Math.round((ev.clientX - drag.dx) / 10) * 10)\n  drag.n.y = Math.max(0, Math.round((ev.clientY - drag.dy) / 10) * 10)\n  drawGraph()\n})\nwindow.addEventListener('mouseup', () => { if (drag && drag.moved) save(); drag = null })\nwindow.addEventListener('keydown', ev => {\n  if (ev.key === 'Escape') cancelLink(true)\n  if ((ev.key === 'Backspace' || ev.key === 'Delete') && selNode && !/INPUT|TEXTAREA/.test(document.activeElement.tagName)) deleteNode()\n})\nfunction cancelLink(rerender){ linkSrc = null; linkKind = null; if (rerender) render() }\n\nfunction clickNode(n){\n  if (linkSrc && linkSrc !== n.id) {\n    const s = nodeOf(linkSrc)\n    if (s) s[linkKind === 'done' ? 'onDone' : 'onFail'] = n.id // cycles are legal — visit caps break loops at run time\n    cancelLink()\n    save(); render()\n    return\n  }\n  selNode = n.id\n  render()\n}\n\nfunction drawEditor(){\n  const w = wf()\n  const n = w && w.nodes.find(x => x.id === selNode)\n  const ed = document.getElementById('editor')\n  ed.style.display = n ? 'flex' : 'none'\n  if (!n) return\n  document.getElementById('eTitle').value = n.title\n  document.getElementById('eDesc').value = n.description || ''\n  document.getElementById('eCrit').value = (n.criteria || []).join('\\n')\n  document.getElementById('eCwd').value = n.cwd || ''\n  document.getElementById('eMax').value = n.maxVisits || ''\n  document.getElementById('eIso').checked = !!n.isolate\n  const name = id => { const t = nodeOf(id); return t ? '→ ' + t.title : null }\n  document.getElementById('tDone').textContent = name(n.onDone) || '— halt (success)'\n  document.getElementById('tFail').textContent = name(n.onFail) || '— halt (failure)'\n}\nfunction saveNode(){\n  const n = nodeOf(selNode); if (!n) return\n  n.title = document.getElementById('eTitle').value.trim() || n.title\n  n.description = document.getElementById('eDesc').value\n  n.criteria = document.getElementById('eCrit').value.split('\\n').map(x => x.trim()).filter(Boolean)\n  n.cwd = document.getElementById('eCwd').value.trim()\n  n.maxVisits = Math.max(0, Math.min(9, parseInt(document.getElementById('eMax').value, 10) || 0)) || undefined\n  n.isolate = document.getElementById('eIso').checked\n  save(); render()\n}\nfunction deleteNode(){\n  const w = wf()\n  w.nodes = w.nodes.filter(x => x.id !== selNode)\n  for (const n of w.nodes) {\n    if (n.onDone === selNode) n.onDone = null\n    if (n.onFail === selNode) n.onFail = null\n  }\n  if (w.start === selNode) w.start = w.nodes[0] && w.nodes[0].id\n  selNode = null; cancelLink()\n  save(); render()\n}\nfunction linkFrom(kind){ if (!selNode) return; linkSrc = selNode; linkKind = kind; render() }\nfunction clearLink(field){ const n = nodeOf(selNode); if (!n) return; n[field] = null; save(); render() }\nfunction setStart(){ const w = wf(); if (w && selNode) { w.start = selNode; save(); render() } }\n\nfunction renameWf(name){\n  const w = wf(); if (!w) return\n  w.name = name.trim() || w.name\n  save(); render()\n}\nfunction addWorkflow(){\n  const id = 'w' + Date.now().toString(36)\n  workflows.push({ id, name: 'workflow ' + (workflows.length + 1), cron: '', cronOn: false, start: null, nodes: [] })\n  selWf = id; selNode = null\n  save(); render()\n}\nfunction seedDemo(){\n  const id = 'w' + Date.now().toString(36)\n  const mk = (nid, title, description, x, y, criteria) => ({ id: nid, title, description, criteria: criteria || [], x, y, onDone: null, onFail: null })\n  const plan = mk('plan', 'plan', 'Study the codebase and write IMPLEMENTATION_PLAN.md for the change described in this workflow run.', 40, 130, ['plan file exists with concrete steps'])\n  const impl = mk('impl', 'implement', 'Implement the change following IMPLEMENTATION_PLAN.md.', 290, 130, ['typecheck passes', 'lint passes'])\n  const test = mk('test', 'verify', 'Run the full test suite and typecheck; fix nothing — only verify and report.', 540, 130, ['test suite green'])\n  const fix = mk('fix', 'fix failures', 'The verify step failed. Diagnose the failing tests/typecheck and repair the implementation.', 540, 300, ['previously failing checks now pass'])\n  const rel = mk('rel', 'release notes', 'Summarize what shipped into RELEASE_NOTES.md.', 790, 130, [])\n  plan.onDone = 'impl'\n  impl.onDone = 'test'\n  test.onDone = 'rel'\n  test.onFail = 'fix'      // failure branch…\n  fix.onDone = 'test'      // …loops back to verify (visit-capped)\n  fix.maxVisits = 2\n  workflows.push({ id, name: 'ship a change', cron: '', cronOn: false, start: 'plan', nodes: [plan, impl, test, fix, rel] })\n  selWf = id\n  save(); render()\n}\nlet delArmed = 0\nasync function removeWorkflow(){\n  const w = wf(); if (!w) return\n  if (Date.now() - delArmed > 2500) { // two-click confirm — sandbox blocks modals\n    delArmed = Date.now()\n    document.getElementById('delWf').textContent = 'sure? click again'\n    setTimeout(() => { document.getElementById('delWf').textContent = 'Delete' }, 2600)\n    return\n  }\n  if (w.cronOn) await call('schedules.remove', 'wf-' + w.id).catch(() => {})\n  workflows = workflows.filter(x => x.id !== w.id)\n  selWf = workflows.length ? workflows[0].id : null\n  document.getElementById('delWf').textContent = 'Delete'\n  save(); render()\n}\nfunction addNode(){\n  const w = wf(); if (!w) return\n  const id = 'n' + Date.now().toString(36)\n  w.nodes.push({ id, title: 'step ' + (w.nodes.length + 1), description: '', criteria: [], onDone: null, onFail: null, x: 60 + (w.nodes.length % 5) * 210, y: 60 + Math.floor(w.nodes.length / 5) * 110 })\n  if (!w.start) w.start = id\n  selNode = id\n  save(); render()\n}\n\nasync function runNow(){\n  const w = wf()\n  if (!w || !w.nodes.length) return\n  try {\n    const allRuns = (await call('storage.get', 'runs')) || []\n    if (allRuns.some(r => r.wfId === w.id && r.status === 'running')) { banner('a run of this machine is already going'); return }\n    const start = w.nodes.find(n => n.id === w.start) || w.nodes[0]\n    const run = { id: 'run' + Date.now().toString(36), wfId: w.id, wfName: w.name, startedAt: Date.now(), status: 'running', trigger: 'manual', current: start.id, taskId: null, visits: {}, path: [] }\n    const taskId = await call('tasks.add', start.title, 'backlog', {\n      description: ['[workflow \"' + w.name + '\" · run ' + run.id + ' · step ' + start.id + ']', start.description || ''].filter(Boolean).join('\\n\\n'),\n      criteria: start.criteria || [], cwd: start.cwd || undefined, isolate: start.isolate === true ? true : undefined,\n    })\n    await call('tasks.start', taskId)\n    run.taskId = taskId\n    run.visits[start.id] = 1\n    run.path.push({ nodeId: start.id, title: start.title, taskId, outcome: 'running', at: Date.now() })\n    await call('storage.set', 'runs', [run, ...allRuns].slice(0, 30))\n    await call('flash', 'machine entered \"' + start.title + '\"')\n  } catch (e) { banner(e.message) }\n  refreshRuns()\n}\n\nfunction cronPreset(){\n  const v = document.getElementById('cronSel').value\n  document.getElementById('cron').style.display = v === 'custom' ? '' : 'none'\n  if (v && v !== 'custom') document.getElementById('cron').value = v\n}\nasync function toggleCron(){\n  const w = wf(); if (!w) return\n  try {\n    if (w.cronOn) {\n      await call('schedules.remove', 'wf-' + w.id)\n      w.cronOn = false\n    } else {\n      const sel = document.getElementById('cronSel').value\n      const cron = (sel === 'custom' ? document.getElementById('cron').value : sel).trim()\n      if (cron.split(/\\s+/).length !== 5) { banner('pick a preset or give a 5-field cron, e.g. 0 6 * * *'); return }\n      const res = await call('schedules.add', { name: 'wf-' + w.id, schedule: cron })\n      if (typeof res === 'string' && res.indexOf('created') === -1) { banner(res); return }\n      w.cron = cron\n      w.cronOn = true\n    }\n  } catch (e) { banner(e.message); return }\n  save(); render()\n}\n\nasync function refreshRuns(){\n  try { runs = (await call('storage.get', 'runs')) || [] } catch (e) { return }\n  const mine = runs.filter(x => !selWf || x.wfId === selWf)\n  document.getElementById('histCount').textContent = mine.length ? '· ' + mine.length : ''\n  const el = document.getElementById('runList')\n  el.innerHTML = ''\n  for (const r of mine.slice(0, 10)) {\n    const steps = r.path || []\n    const dur = r.finishedAt ? Math.max(1, Math.round((r.finishedAt - r.startedAt) / 60000)) + ' min' : ''\n    const d = document.createElement('div')\n    d.className = 'run' + (openRun === r.id ? ' open' : '')\n    const pathHtml = steps.map((p, i) => {\n      const via = i ? `<span class=\"via ${p.via || ''}\">${p.via === 'failed' ? '✗→' : '✓→'}</span>` : ''\n      return via + `<span class=\"step\"><span class=\"dot ${p.outcome}\"></span>${esc(p.title || p.nodeId)}</span>`\n    }).join('')\n    d.innerHTML = `<div class=\"head\"><span class=\"st ${r.status}\">${r.status}</span>`\n      + `<b style=\"font-size:12px\">${esc(r.wfName)}</b>`\n      + `<span class=\"meta\">${steps.length} step(s)${dur ? ' · ' + dur : ''} · ${r.trigger || 'manual'} · ${ago(r.startedAt)}</span>`\n      + `<span style=\"flex:1\"></span><span class=\"meta\">${openRun === r.id ? '▾' : '▸'}</span></div>`\n      + `<div class=\"path\">${pathHtml || '<span class=\"empty\">no steps recorded</span>'}</div>`\n    d.onclick = () => { openRun = openRun === r.id ? null : r.id; refreshRuns() }\n    el.appendChild(d)\n  }\n  if (!mine.length) el.innerHTML = '<div class=\"empty\">no runs yet — hit ▶ Run now or arm a cron trigger</div>'\n  drawGraph() // repaint live step stripes\n}\n\ndocument.getElementById('svg').onclick = () => { selNode = null; cancelLink(); render() }\nload()\nparent.postMessage({ type: 'yaam:getState' }, '*')\n</script></body></html>\n"
}
