{
  "manifest": 3,
  "name": "Workflows",
  "version": "1.0.0",
  "icon": "⛓",
  "description": "Task pipelines as a DAG — draw nodes (task specs) and dependency edges, run the graph on demand or on a cron, and watch each run advance as the board tasks it spawned reach done. Full run history included.",
  "author": "yaam",
  "permissions": [
    "state:read",
    "tasks",
    "schedules",
    "storage",
    "ui"
  ],
  "hooks": {
    "onTaskMoved": "// (input = { taskId, title, col, from }, api) — a board task changed column.\n// If it belongs to a running workflow run, advance the DAG: a node whose task\n// reached done unlocks every dependent whose deps are now all done; a failed\n// task fails the whole run (dependents would build on broken output).\nif (input.col !== 'done' && input.col !== 'failed') return\n\nconst runs = (await api.storage.get('runs')) || []\nconst run = runs.find(r => r.status === 'running' && Object.values(r.nodes).some(n => n.taskId === input.taskId))\nif (!run) return\n\nconst workflows = (await api.storage.get('workflows')) || []\nconst wf = workflows.find(w => w.id === run.wfId)\n\nconst nodeId = Object.keys(run.nodes).find(id => run.nodes[id].taskId === input.taskId)\nrun.nodes[nodeId].status = input.col === 'done' ? 'done' : 'failed'\n\nif (input.col === 'failed') {\n  run.status = 'failed'\n  run.finishedAt = Date.now()\n  await api.storage.set('runs', runs)\n  await api.notify('Workflow failed', `\"${run.wfName}\" — node \"${input.title}\" failed; downstream nodes not started`)\n  return\n}\n\n// start every dependent whose dependencies are now all done\nif (wf) {\n  for (const n of wf.nodes) {\n    const cell = run.nodes[n.id]\n    if (!cell || cell.status !== 'pending') continue\n    const deps = n.deps || []\n    if (!deps.length || !deps.every(d => run.nodes[d] && run.nodes[d].status === 'done')) continue\n    const taskId = await api.tasks.add(n.title, 'backlog', {\n      description: [`[workflow \"${wf.name}\" · run ${run.id} · node ${n.id}]`, n.description || ''].filter(Boolean).join('\\n\\n'),\n      criteria: n.criteria || [],\n      cwd: n.cwd || undefined,\n      isolate: n.isolate === true ? true : undefined,\n    })\n    await api.tasks.start(taskId)\n    run.nodes[n.id] = { taskId, status: 'running' }\n  }\n}\n\nif (Object.values(run.nodes).every(n => n.status === 'done')) {\n  run.status = 'done'\n  run.finishedAt = Date.now()\n  await api.notify('Workflow finished', `\"${run.wfName}\" — every node is done`)\n}\n\nawait api.storage.set('runs', runs)\n",
    "onCronFired": "// (input = { name, kind }, api) — a schedule fired. Workflow triggers are\n// schedules named \"wf-<workflow id>\" created from the Workflows tab; when one\n// fires, start a run of that workflow: spawn every root node (no deps) as a\n// board task and record the run in history.\nif (!String(input.name || '').startsWith('wf-')) return\n\nconst wfId = String(input.name).slice(3)\nconst workflows = (await api.storage.get('workflows')) || []\nconst wf = workflows.find(w => w.id === wfId)\nif (!wf || !Array.isArray(wf.nodes) || !wf.nodes.length) return\n\n// one running run per workflow — a slow pipeline must not stack on itself\nconst runs = (await api.storage.get('runs')) || []\nif (runs.some(r => r.wfId === wf.id && r.status === 'running')) {\n  await api.logEvent(`workflow \"${wf.name}\" skipped a cron trigger — previous run still going`)\n  return\n}\n\nconst run = {\n  id: 'run' + Date.now().toString(36),\n  wfId: wf.id, wfName: wf.name, startedAt: Date.now(), status: 'running',\n  trigger: 'cron', nodes: {},\n}\nfor (const n of wf.nodes) run.nodes[n.id] = { taskId: null, status: 'pending' }\n\n// start every root (a node whose deps are all… nonexistent)\nfor (const n of wf.nodes) {\n  if ((n.deps || []).length) continue\n  const taskId = await api.tasks.add(n.title, 'backlog', {\n    description: [`[workflow \"${wf.name}\" · run ${run.id} · node ${n.id}]`, n.description || ''].filter(Boolean).join('\\n\\n'),\n    criteria: n.criteria || [],\n    cwd: n.cwd || undefined,\n    isolate: n.isolate === true ? true : undefined,\n  })\n  await api.tasks.start(taskId)\n  run.nodes[n.id] = { taskId, status: 'running' }\n}\n\nawait api.storage.set('runs', [run, ...runs].slice(0, 30))\nawait api.notify('Workflow started', `\"${wf.name}\" — ${Object.values(run.nodes).filter(x => x.status === 'running').length} root task(s) launched`)\n"
  },
  "html": "<!DOCTYPE html><html><head><style>\nbody{margin:0;background:#0A0B0F;color:#E7E9F0;font-family:'IBM Plex Sans',system-ui,sans-serif;display:flex;height:100vh;overflow:hidden}\n#side{width:240px;border-right:1px solid #1a1e26;padding:16px;display:flex;flex-direction:column;gap:6px;overflow-y:auto}\nh1{font-size:14px;margin:0 0 2px;display:flex;gap:8px;align-items:center}\nsmall{color:#8B93A1;font-size:11px}\nh2{font-size:10.5px;letter-spacing:.5px;color:#8B93A1;margin:14px 0 4px;text-transform:uppercase}\n.wf{background:#12151C;border:1px solid #1a1e26;border-radius:8px;padding:8px 10px;font-size:12.5px;cursor:pointer;display:flex;gap:8px;align-items:center}\n.wf.sel{border-color:rgba(245,196,81,.5)}\n.wf b{flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-weight:600}\nbutton{background:transparent;border:1px solid #2a2f3a;border-radius:7px;color:#E7E9F0;font-size:11px;padding:4px 10px;cursor:pointer}\nbutton:hover{border-color:#F5C451;color:#F5C451}\nbutton.primary{border-color:rgba(61,220,151,.5);color:#3DDC97}\nbutton.danger:hover{border-color:#FF5C5C;color:#FF5C5C}\ninput,textarea{background:#0A0B0F;border:1px solid #2a2f3a;border-radius:7px;color:#E7E9F0;font-size:11.5px;padding:5px 8px;outline:none;font-family:inherit;width:100%;box-sizing:border-box}\n#main{flex:1;display:flex;flex-direction:column;min-width:0}\n#bar{display:flex;gap:8px;align-items:center;padding:10px 14px;border-bottom:1px solid #1a1e26;flex-wrap:wrap}\n#canvasWrap{flex:1;position:relative;overflow:auto}\nsvg{display:block}\n.node rect{fill:#12151C;stroke:#2a2f3a;rx:9}\n.node.sel rect{stroke:#F5C451}\n.node text{fill:#E7E9F0;font-size:12px;font-weight:600;pointer-events:none}\n.node .sub{fill:#8B93A1;font-size:9.5px;font-weight:400}\n.edge{stroke:#3a4150;stroke-width:1.6;fill:none;marker-end:url(#arr);cursor:pointer}\n.edge:hover{stroke:#FF5C5C}\n#editor{position:absolute;right:12px;top:12px;width:250px;background:#12151C;border:1px solid #2a2f3a;border-radius:10px;padding:12px;display:none;flex-direction:column;gap:6px;box-shadow:0 12px 30px rgba(0,0,0,.5)}\n#editor label{font-size:10px;color:#8B93A1;letter-spacing:.4px;text-transform:uppercase}\n#hist{max-height:200px;overflow-y:auto;border-top:1px solid #1a1e26;padding:10px 14px}\n.run{font-family:'JetBrains Mono',monospace;font-size:10.5px;color:#8B93A1;padding:4px 0;display:flex;gap:10px;align-items:center}\n.run .st-done{color:#3DDC97}.run .st-failed{color:#FF5C5C}.run .st-running{color:#F5C451}\n.dot{width:6px;height:6px;border-radius:50%;background:#3a4150;display:inline-block;margin-right:2px}\n.dot.done{background:#3DDC97}.dot.failed{background:#FF5C5C}.dot.running{background:#F5C451}\n#hint{font-size:10.5px;color:#5a6170;padding:4px 14px}\n.chk{display:flex;gap:6px;align-items:center;font-size:11px;color:#8B93A1}\n.chk input{width:auto}\n</style></head><body>\n<div id=\"side\">\n  <h1>⛓ Workflows</h1>\n  <small>DAG pipelines over board tasks</small>\n  <h2>Pipelines</h2>\n  <div id=\"wfList\"></div>\n  <button onclick=\"addWorkflow()\">+ New workflow</button>\n</div>\n<div id=\"main\">\n  <div id=\"bar\">\n    <b id=\"wfName\" style=\"font-size:13px\"></b>\n    <button class=\"primary\" onclick=\"runNow()\">▶ Run now</button>\n    <button onclick=\"addNode()\">+ Node</button>\n    <span style=\"flex:1\"></span>\n    <input id=\"cron\" placeholder=\"0 6 * * *\" style=\"width:110px;font-family:'JetBrains Mono',monospace\">\n    <button id=\"cronBtn\" onclick=\"toggleCron()\">Enable cron</button>\n    <button class=\"danger\" onclick=\"removeWorkflow()\">Delete</button>\n  </div>\n  <div id=\"hint\">drag nodes to arrange · “link →” then click a target to draw a dependency · click an edge to remove it</div>\n  <div id=\"canvasWrap\"><svg id=\"svg\" width=\"1600\" height=\"900\">\n    <defs><marker id=\"arr\" viewBox=\"0 0 8 8\" refX=\"7\" refY=\"4\" markerWidth=\"7\" markerHeight=\"7\" orient=\"auto\"><path d=\"M0,0 L8,4 L0,8 z\" fill=\"#3a4150\"/></marker></defs>\n    <g id=\"edges\"></g><g id=\"nodes\"></g>\n  </svg></div>\n  <div id=\"editor\">\n    <label>Title</label><input id=\"eTitle\">\n    <label>Description (what the agent should do)</label><textarea id=\"eDesc\" rows=\"4\"></textarea>\n    <label>Acceptance criteria — one per line</label><textarea id=\"eCrit\" rows=\"3\"></textarea>\n    <label>Working directory</label><input id=\"eCwd\" placeholder=\"(workspace default)\">\n    <div class=\"chk\"><input type=\"checkbox\" id=\"eIso\"><span>isolate in a git worktree</span></div>\n    <div style=\"display:flex;gap:6px;margin-top:4px\">\n      <button class=\"primary\" style=\"flex:1\" onclick=\"saveNode()\">Save</button>\n      <button onclick=\"linkFrom()\">link →</button>\n      <button class=\"danger\" onclick=\"deleteNode()\">✕</button>\n    </div>\n  </div>\n  <div id=\"hist\"><h2 style=\"margin-top:0\">Run history</h2><div id=\"runList\"></div></div>\n</div>\n<script>\n'use strict'\nlet seq = 0\nconst pending = {}\nfunction call(method, ...args){\n  return new Promise((resolve, reject) => {\n    const callId = 'c' + (++seq)\n    pending[callId] = { resolve, reject }\n    parent.postMessage({ type: 'yaam:call', callId, method, args }, '*')\n  })\n}\nwindow.addEventListener('message', e => {\n  const d = e.data\n  if (d && d.type === 'yaam:result' && pending[d.callId]) {\n    d.error ? pending[d.callId].reject(new Error(d.error)) : pending[d.callId].resolve(d.result)\n    delete pending[d.callId]\n  }\n  if (d && d.type === 'yaam:state') refreshRuns() // state push ≈ every 3s — reuse as our poll tick\n})\n\nlet workflows = [], runs = [], selWf = null, selNode = null, linkSrc = null\n\nconst esc = t => String(t == null ? '' : t).replace(/[&<>\"]/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','\"':'&quot;'}[c]))\nconst wf = () => workflows.find(w => w.id === selWf)\n\nasync function load(){\n  workflows = (await call('storage.get', 'workflows')) || []\n  if (!selWf && workflows.length) selWf = workflows[0].id\n  render()\n  refreshRuns()\n}\nconst save = () => call('storage.set', 'workflows', workflows)\n\nfunction render(){\n  const list = document.getElementById('wfList')\n  list.innerHTML = ''\n  for (const w of workflows) {\n    const el = document.createElement('div')\n    el.className = 'wf' + (w.id === selWf ? ' sel' : '')\n    el.innerHTML = `<b>${esc(w.name)}</b><small>${w.nodes.length}</small>`\n    el.onclick = () => { selWf = w.id; selNode = null; render() }\n    list.appendChild(el)\n  }\n  const w = wf()\n  document.getElementById('wfName').textContent = w ? w.name : '—'\n  document.getElementById('cron').value = w && w.cron ? w.cron : ''\n  document.getElementById('cronBtn').textContent = w && w.cronOn ? 'Disable cron' : 'Enable cron'\n  drawGraph()\n  drawEditor()\n}\n\nfunction drawGraph(){\n  const w = wf()\n  const gN = document.getElementById('nodes'), gE = document.getElementById('edges')\n  gN.innerHTML = ''; gE.innerHTML = ''\n  if (!w) return\n  const byId = {}\n  for (const n of w.nodes) byId[n.id] = n\n  for (const n of w.nodes) for (const d of (n.deps || [])) {\n    const s = byId[d]; if (!s) continue\n    const p = document.createElementNS('http://www.w3.org/2000/svg', 'path')\n    const x1 = s.x + 150, y1 = s.y + 24, x2 = n.x, y2 = n.y + 24\n    p.setAttribute('d', `M${x1},${y1} C${x1 + 50},${y1} ${x2 - 50},${y2} ${x2},${y2}`)\n    p.setAttribute('class', 'edge')\n    p.onclick = () => { n.deps = n.deps.filter(x => x !== d); save(); render() }\n    gE.appendChild(p)\n  }\n  for (const n of w.nodes) {\n    const g = document.createElementNS('http://www.w3.org/2000/svg', 'g')\n    g.setAttribute('class', 'node' + (n.id === selNode ? ' sel' : ''))\n    g.setAttribute('transform', `translate(${n.x},${n.y})`)\n    const crit = (n.criteria || []).length\n    g.innerHTML = `<rect width=\"150\" height=\"48\" rx=\"9\"/><text x=\"10\" y=\"20\">${esc(n.title.slice(0, 18))}</text><text x=\"10\" y=\"36\" class=\"sub\">${(n.deps || []).length ? '⤝ ' + (n.deps || []).length + ' dep(s) · ' : ''}${crit ? crit + ' criteria' : 'no criteria'}${n.isolate ? ' · ⑂' : ''}</text>`\n    g.onmousedown = ev => startDrag(ev, n)\n    g.onclick = ev => { ev.stopPropagation(); clickNode(n) }\n    gN.appendChild(g)\n  }\n}\n\nlet drag = null\nfunction startDrag(ev, n){ drag = { n, dx: ev.clientX - n.x, dy: ev.clientY - n.y, moved: false } }\nwindow.addEventListener('mousemove', ev => {\n  if (!drag) return\n  drag.moved = true\n  drag.n.x = Math.max(0, ev.clientX - drag.dx)\n  drag.n.y = Math.max(0, ev.clientY - drag.dy)\n  drawGraph()\n})\nwindow.addEventListener('mouseup', () => { if (drag && drag.moved) save(); drag = null })\n\nfunction clickNode(n){\n  if (linkSrc && linkSrc !== n.id) {\n    // an edge means \"n depends on linkSrc\" — reject cycles with a reach check\n    if (reaches(n.id, linkSrc)) { linkSrc = null; return }\n    n.deps = [...new Set([...(n.deps || []), linkSrc])]\n    linkSrc = null\n    save(); render()\n    return\n  }\n  selNode = n.id\n  render()\n}\nfunction reaches(from, to){\n  const w = wf(); const byId = {}\n  for (const x of w.nodes) byId[x.id] = x\n  const stack = [from], seen = new Set()\n  while (stack.length) {\n    const cur = stack.pop()\n    if (cur === to) return true\n    if (seen.has(cur)) continue\n    seen.add(cur)\n    for (const d of (byId[cur] && byId[cur].deps) || []) stack.push(d)\n  }\n  return false\n}\n\nfunction drawEditor(){\n  const w = wf()\n  const n = w && w.nodes.find(x => x.id === selNode)\n  const ed = document.getElementById('editor')\n  ed.style.display = n ? 'flex' : 'none'\n  if (!n) return\n  document.getElementById('eTitle').value = n.title\n  document.getElementById('eDesc').value = n.description || ''\n  document.getElementById('eCrit').value = (n.criteria || []).join('\\n')\n  document.getElementById('eCwd').value = n.cwd || ''\n  document.getElementById('eIso').checked = !!n.isolate\n}\nfunction saveNode(){\n  const n = wf().nodes.find(x => x.id === selNode); if (!n) return\n  n.title = document.getElementById('eTitle').value.trim() || n.title\n  n.description = document.getElementById('eDesc').value\n  n.criteria = document.getElementById('eCrit').value.split('\\n').map(x => x.trim()).filter(Boolean)\n  n.cwd = document.getElementById('eCwd').value.trim()\n  n.isolate = document.getElementById('eIso').checked\n  save(); render()\n}\nfunction deleteNode(){\n  const w = wf()\n  w.nodes = w.nodes.filter(x => x.id !== selNode)\n  for (const n of w.nodes) n.deps = (n.deps || []).filter(d => d !== selNode)\n  selNode = null\n  save(); render()\n}\nfunction linkFrom(){ linkSrc = selNode }\n\nfunction addWorkflow(){\n  const id = 'w' + Date.now().toString(36)\n  workflows.push({ id, name: 'workflow ' + (workflows.length + 1), cron: '', cronOn: false, nodes: [] })\n  selWf = id\n  save(); render()\n}\nasync function removeWorkflow(){\n  const w = wf(); if (!w) return\n  if (w.cronOn) await call('schedules.remove', 'wf-' + w.id)\n  workflows = workflows.filter(x => x.id !== w.id)\n  selWf = workflows.length ? workflows[0].id : null\n  save(); render()\n}\nfunction addNode(){\n  const w = wf(); if (!w) return\n  const id = 'n' + Date.now().toString(36)\n  w.nodes.push({ id, title: 'step ' + (w.nodes.length + 1), description: '', criteria: [], deps: [], x: 40 + (w.nodes.length % 5) * 180, y: 40 + Math.floor(w.nodes.length / 5) * 90 })\n  selNode = id\n  save(); render()\n}\n\nasync function runNow(){\n  const w = wf()\n  if (!w || !w.nodes.length) return\n  const allRuns = (await call('storage.get', 'runs')) || []\n  if (allRuns.some(r => r.wfId === w.id && r.status === 'running')) { await call('flash', 'a run of this workflow is already going'); return }\n  const run = { id: 'run' + Date.now().toString(36), wfId: w.id, wfName: w.name, startedAt: Date.now(), status: 'running', trigger: 'manual', nodes: {} }\n  for (const n of w.nodes) run.nodes[n.id] = { taskId: null, status: 'pending' }\n  for (const n of w.nodes) {\n    if ((n.deps || []).length) continue\n    const taskId = await call('tasks.add', n.title, 'backlog', {\n      description: ['[workflow \"' + w.name + '\" · run ' + run.id + ' · node ' + n.id + ']', n.description || ''].filter(Boolean).join('\\n\\n'),\n      criteria: n.criteria || [], cwd: n.cwd || undefined, isolate: n.isolate === true ? true : undefined,\n    })\n    await call('tasks.start', taskId)\n    run.nodes[n.id] = { taskId, status: 'running' }\n  }\n  await call('storage.set', 'runs', [run, ...allRuns].slice(0, 30))\n  await call('flash', 'workflow started — root tasks launched')\n  refreshRuns()\n}\n\nasync function toggleCron(){\n  const w = wf(); if (!w) return\n  if (w.cronOn) {\n    await call('schedules.remove', 'wf-' + w.id)\n    w.cronOn = false\n  } else {\n    const cron = document.getElementById('cron').value.trim()\n    if (cron.split(/\\s+/).length !== 5) { await call('flash', 'cron needs 5 fields, e.g. 0 6 * * *'); return }\n    const res = await call('schedules.add', { name: 'wf-' + w.id, schedule: cron })\n    if (typeof res === 'string' && res.indexOf('created') === -1) { await call('flash', res); return }\n    w.cron = cron\n    w.cronOn = true\n  }\n  save(); render()\n}\n\nasync function refreshRuns(){\n  runs = (await call('storage.get', 'runs')) || []\n  const el = document.getElementById('runList')\n  el.innerHTML = ''\n  for (const r of runs.filter(x => !selWf || x.wfId === selWf).slice(0, 12)) {\n    const dots = Object.values(r.nodes).map(n => `<span class=\"dot ${n.status}\"></span>`).join('')\n    const row = document.createElement('div')\n    row.className = 'run'\n    row.innerHTML = `<span class=\"st-${r.status}\">${r.status}</span><span>${esc(r.wfName)}</span><span>${dots}</span><span>${new Date(r.startedAt).toLocaleString()}</span><span>${r.trigger || ''}</span>`\n    el.appendChild(row)\n  }\n  if (!el.children.length) el.innerHTML = '<div class=\"run\">no runs yet</div>'\n}\n\ndocument.getElementById('svg').onclick = () => { selNode = null; linkSrc = null; render() }\nload()\nparent.postMessage({ type: 'yaam:getState' }, '*')\n</script></body></html>\n"
}
